        <style>
            :root {
                --accent-color: #39ff14;
                --primary-bg: #14121c;
                --mauve-deep: #2b2440;
                --mauve-mid: #805ad5;
                --mauve-light: #b794f4;
            }

            /* Fond IMMONDE : marécage organique vert/violet qui ondule lentement */
            body {
                background-color: #0a1208;
                background-image:
                    radial-gradient(ellipse 60% 50% at 15% 10%, rgba(57, 255, 20, 0.22), transparent 55%),
                    radial-gradient(ellipse 50% 60% at 85% 25%, rgba(128, 90, 213, 0.28), transparent 55%),
                    radial-gradient(ellipse 70% 50% at 50% 95%, rgba(31, 143, 8, 0.30), transparent 60%),
                    radial-gradient(ellipse 40% 40% at 70% 70%, rgba(68, 51, 122, 0.25), transparent 55%);
                background-attachment: fixed;
                background-size: 200% 200%;
                animation: immonde-ooze 28s ease-in-out infinite;
            }
            @keyframes immonde-ooze {
                0%, 100% { background-position: 0% 0%, 100% 0%, 50% 100%, 70% 70%; }
                50%      { background-position: 10% 20%, 80% 30%, 40% 80%, 60% 50%; }
            }

            /* ===================================================== */
            /*  FOND IMMONDE — coulures de bave verte qui dégoulinent */
            /*  Placé DERRIÈRE le contenu (z-index 0) : le bloc       */
            /*  central reste opaque et lisible par-dessus.          */
            /* ===================================================== */
            #slime-bg {
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                overflow: hidden;
                opacity: 0.95;
            }
            /* Une coulure = une barre verticale accrochée en haut, qui s'allonge,
               coiffée d'une goutte renflée au bout. */
            .slime-drip-bg {
                position: absolute;
                top: -40px;
                width: 10px;
                border-bottom-left-radius: 50% 18px;
                border-bottom-right-radius: 50% 18px;
                background: linear-gradient(180deg, #2bbf0e 0%, #39ff14 55%, #7dff5c 100%);
                box-shadow: 0 0 14px rgba(57, 255, 20, 0.45);
                transform-origin: top center;
                animation: bg-drip-grow var(--dur, 7s) ease-in-out var(--delay, 0s) infinite;
            }
            /* La goutte au bout de la coulure */
            .slime-drip-bg::after {
                content: "";
                position: absolute;
                bottom: -9px;
                left: 50%;
                width: 18px;
                height: 22px;
                transform: translateX(-50%);
                border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;
                background: radial-gradient(circle at 35% 30%, #9dff7a, #39ff14 60%, #1f8f08);
                box-shadow: 0 0 12px rgba(57, 255, 20, 0.5);
            }
            @keyframes bg-drip-grow {
                0%       { height: 40px;  opacity: 0; }
                12%      { opacity: 1; }
                55%      { height: var(--len, 160px); }
                88%      { height: var(--len, 160px); opacity: 1; }
                100%     { height: calc(var(--len, 160px) + 10px); opacity: 0; }
            }

            /* Gouttes détachées qui tombent jusqu'en bas */
            .slime-fall-bg {
                position: absolute;
                top: -30px;
                width: 14px;
                height: 18px;
                border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;
                background: radial-gradient(circle at 35% 30%, #9dff7a, #39ff14 60%, #1f8f08);
                box-shadow: 0 0 10px rgba(57, 255, 20, 0.5);
                animation: bg-fall var(--dur, 9s) cubic-bezier(0.5, 0, 0.9, 1) var(--delay, 0s) infinite;
            }
            @keyframes bg-fall {
                0%   { transform: translateY(0) scaleY(0.8); opacity: 0; }
                8%   { opacity: 0.9; }
                90%  { opacity: 0.9; }
                100% { transform: translateY(105vh) scaleY(1.5); opacity: 0; }
            }

            /* Sur petit écran : un peu moins dense pour rester lisible */
            @media (max-width: 768px) {
                #slime-bg { opacity: 0.7; }
            }

            .main-content-container {
                background: linear-gradient(180deg, rgba(28, 24, 40, 0.92) 0%, rgba(18, 16, 26, 0.96) 100%);
                position: relative;
                box-shadow: 0 12px 50px rgba(0, 0, 0, 0.45);
                z-index: 20;
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 1.5rem;
            }
            /* Fin liseré vert en haut du conteneur — touche d'identité, discrète */
            .main-content-container::before {
                content: "";
                position: absolute;
                top: 0;
                left: 10%;
                right: 10%;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
                opacity: 0.5;
                border-radius: 2px;
            }

            @keyframes scan-slow {
                0% { transform: translateY(-100%); }
                100% { transform: translateY(1000%); }
            }

            .animate-scan-slow {
                animation: scan-slow 8s linear infinite;
            }

            /* glitch-hover : neutralisé — simple mise en avant, plus de tremblement infini */
            .glitch-hover {
                transition: text-shadow 0.3s ease, color 0.3s ease;
            }
            .glitch-hover:hover {
                text-shadow: 0 0 12px rgba(57, 255, 20, 0.5);
            }

            @keyframes spooky-float {
                0%, 100% { transform: translateY(0); }
                50% { transform: translateY(-6px); }
            }

            .spooky-float {
                animation: spooky-float 5s ease-in-out infinite;
            }

            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                25% { transform: translateX(-5px) rotate(-1deg); }
                75% { transform: translateX(5px) rotate(1deg); }
            }

            .shake {
                animation: shake 0.1s ease-in-out infinite;
            }

            img, video, iframe {
                max-width: 100%;
                height: auto;
                border-radius: 1rem;
            }

            @media (max-width: 768px) {
                #target-container {
                    padding: 1rem;
                    padding-top: 2rem;
                }
                .font-mystere {
                    letter-spacing: 0.1em;
                }
                .main-content-container {
                    border-radius: 1rem;
                }
            }

            .distort-hover {
                transition: transform 0.25s ease;
            }
            .distort-hover:hover {
                transform: scale(1.04);
            }

            /* Nav */
            header {
                backdrop-filter: blur(10px);
                background: rgba(20, 18, 28, 0.9) !important;
            }

            /* Scrollbar */
            ::-webkit-scrollbar { width: 8px; }
            ::-webkit-scrollbar-track { background: var(--primary-bg); }
            ::-webkit-scrollbar-thumb {
                background: var(--mauve-mid);
                border-radius: 10px;
                border: 2px solid var(--primary-bg);
            }
            ::-webkit-scrollbar-thumb:hover { background: var(--accent-color); }

            /* Respecte la préférence système de réduction des animations */
            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after {
                    animation-duration: 0.01ms !important;
                    animation-iteration-count: 1 !important;
                    transition-duration: 0.01ms !important;
                }
            }
        </style>

