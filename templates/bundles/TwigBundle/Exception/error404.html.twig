{% extends 'base.html.twig' %}

{% block title %}Erreur 404 - Dossier Introuvable | Immonde Plus{% endblock %}

{% block body %}
    <div class="max-w-2xl mx-auto text-center py-20">
        <div class="text-accent text-9xl font-mystere mb-8 animate-pulse italic drop-shadow-[0_0_30px_rgba(57,255,20,0.5)]">404</div>
        
        <h1 class="font-mystere text-5xl md:text-7xl text-white mb-6 tracking-widest uppercase italic">Dossier Disparu</h1>
        
        <div class="w-24 h-1 bg-accent mx-auto mb-10 shadow-[0_0_10px_rgba(57,255,20,0.8)]"></div>
        
        <p class="text-xl text-mauve-light mb-12 leading-relaxed font-medium uppercase tracking-widest opacity-80">
            La page que vous recherchez a été aspirée dans une autre dimension <br>
            ou censurée par Mickael Immonde lui-même.
        </p>

        <div class="flex flex-col md:flex-row justify-center gap-6">
            <a href="{{ path('blog_index') }}" class="bg-accent text-primary px-12 py-4 rounded-full font-black uppercase text-xs tracking-widest hover:scale-110 transition-all shadow-[0_0_20px_rgba(57,255,20,0.4)]">
                Sortir de l'ombre
            </a>
            <a href="{{ path('blog_articles') }}" class="border-2 border-accent text-accent px-12 py-4 rounded-full font-black uppercase text-xs tracking-widest hover:bg-accent hover:text-primary transition-all">
                Voir les dossiers restants
            </a>
        </div>
    </div>
{% endblock %}
