{% extends 'base.html.twig' %}

{% block title %}Quel Immonde Es-Tu ? - Test de Personnalité | Imm🧅nde Plus{% endblock %}

{% block body %}
<div id="quiz-portal" class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="mb-12">
        <h1 class="font-mystere text-5xl md:text-7xl text-accent uppercase tracking-widest italic mb-6 glitch-hover">Quel Immonde Es-Tu ?</h1>
        <p class="text-mauve-light font-black uppercase text-xs md:text-sm tracking-[0.4em] flicker">TEST DE PERSONNALITÉ DES ÉGOUTS</p>
    </div>

    <div class="max-w-2xl w-full bg-primary/60 p-8 rounded-3xl border border-mauve-dark mb-10">
        <p class="text-white text-sm font-bold uppercase tracking-widest leading-relaxed opacity-80">
            Réponds honnêtement à ces <span class="text-accent">20 questions</span> pour découvrir quel archétype de l'Immonde sommeille en toi.<br>
            <span class="text-mauve-light text-xs">Résultats garantis non remboursables.</span>
        </p>
    </div>

    <button id="start-btn" class="group relative bg-accent text-primary px-16 py-8 rounded-full font-mystere text-3xl md:text-5xl tracking-widest hover:scale-110 transition-all shadow-[0_0_50px_rgba(57,255,20,0.6)] uppercase animate-pulse">
        RÉVÉLER MON IMMONDE
    </button>
</div>

{# ===== QUIZ CONTAINER ===== #}
<div id="quiz-container" class="hidden max-w-2xl mx-auto px-4 pb-20">

    {# Progress bar #}
    <div class="mb-10">
        <div class="flex justify-between items-center mb-3">
            <span id="question-counter" class="text-accent font-black text-xs uppercase tracking-widest">Question 1 / 7</span>
            <span id="progress-pct" class="text-mauve-light font-black text-xs uppercase tracking-widest">0%</span>
        </div>
        <div class="w-full bg-black/60 rounded-full h-3 border border-mauve-dark overflow-hidden">
            <div id="progress-bar" class="h-full bg-accent rounded-full transition-all duration-500 shadow-[0_0_10px_rgba(57,255,20,0.8)]" style="width:0%"></div>
        </div>
    </div>

    {# Question card #}
    <div id="question-card" class="bg-primary/60 rounded-3xl border-2 border-mauve-dark p-8 md:p-12 shadow-2xl">
        <p id="question-text" class="font-mystere text-2xl md:text-3xl text-white uppercase tracking-wide leading-snug mb-10 text-center"></p>
        <div id="answers-container" class="flex flex-col gap-4"></div>
    </div>
</div>

{# ===== RESULT CONTAINER ===== #}
<div id="result-container" class="hidden max-w-2xl mx-auto px-4 pb-20 text-center">
    <div class="mb-8">
        <h2 class="font-mystere text-4xl md:text-6xl text-accent uppercase tracking-widest italic mb-4 glitch-hover">Résultat</h2>
        <p class="text-mauve-light font-black uppercase text-xs tracking-[0.4em] flicker">ANALYSE COMPLÈTE DES ÉGOUTS</p>
    </div>

    <div class="bg-primary/60 rounded-3xl border-2 border-accent p-8 md:p-12 shadow-[0_0_40px_rgba(57,255,20,0.2)]">
        <div id="result-image-wrapper" class="mb-8 flex justify-center">
            <img id="result-image" src="" alt="Résultat" class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-full border-4 border-accent shadow-[0_0_30px_rgba(57,255,20,0.5)]">
        </div>
        <h3 id="result-title" class="font-mystere text-3xl md:text-5xl text-accent uppercase tracking-widest italic mb-4"></h3>
        <p id="result-subtitle" class="text-mauve-light font-black uppercase text-xs tracking-[0.3em] mb-6"></p>
        <p id="result-description" class="text-white text-sm font-bold uppercase tracking-wider leading-relaxed opacity-80 mb-10"></p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <button id="retry-btn" class="bg-accent text-primary px-10 py-4 rounded-full font-mystere text-xl tracking-widest uppercase hover:scale-105 transition-all shadow-[0_0_20px_rgba(57,255,20,0.4)]">
                RECOMMENCER
            </button>
            <a href="{{ path('blog_games') }}" class="bg-transparent border-2 border-mauve-dark text-mauve-light px-10 py-4 rounded-full font-mystere text-xl tracking-widest uppercase hover:border-accent hover:text-accent transition-all">
                AUTRES JEUX
            </a>
        </div>
    </div>
</div>

