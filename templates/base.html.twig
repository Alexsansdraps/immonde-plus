        {# ============================================================= #}
        {#  LECTEUR MUSIQUE PERSISTANT                                    #}
        {#  Le lecteur est construit en JS et attaché à <html> (HORS du   #}
        {#  <body>). Turbo ne remplace QUE le <body> : un élément placé    #}
        {#  sur documentElement n'est donc jamais re-rendu ni re-parsé,    #}
        {#  l'iframe SoundCloud ne se recharge pas -> la lecture continue. #}
        {# ============================================================= #}
        <script src="https://w.soundcloud.com/player/api.js" data-turbo-eval="false"></script>
        <script data-turbo-eval="false">
            (function () {
                if (window.scPlayerInitialized) return;
                window.scPlayerInitialized = true;

                // --- Fond immonde : coulures de bave (hors <body>, jamais touché par Turbo) ---
                (function buildSlimeBackground() {
                    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

                    var bg = document.createElement('div');
                    bg.id = 'slime-bg';
                    bg.setAttribute('aria-hidden', 'true');

                    var html = '';
                    // Coulures accrochées en haut, réparties sur la largeur — épaisses et visibles
                    var dripCount = window.innerWidth < 768 ? 10 : 18;
                    for (var i = 0; i < dripCount; i++) {
                        var left  = (i / dripCount) * 100 + (i % 2 ? 3 : -2); // réparti + léger décalage
                        var len   = 140 + (i * 37 % 240);  // longueur variée 140-380px
                        var dur   = 6 + (i * 13 % 7);       // durée 6-13s
                        var delay = (i * 17 % 90) / 10;     // délai 0-9s
                        var w     = 12 + (i % 5) * 5;       // largeur 12-32px (épaisses)
                        html += '<span class="slime-drip-bg" style="left:' + left + '%;width:' + w + 'px;'
                              + '--len:' + len + 'px;--dur:' + dur + 's;--delay:' + delay + 's;"></span>';
                    }
                    // Gouttes détachées qui tombent
                    var fallCount = window.innerWidth < 768 ? 6 : 12;
                    for (var j = 0; j < fallCount; j++) {
                        var fLeft  = (j * 53 % 100);
                        var fDur   = 8 + (j * 7 % 6);       // 8-14s
                        var fDelay = (j * 29 % 120) / 10;   // 0-12s
                        html += '<span class="slime-fall-bg" style="left:' + fLeft + '%;'
                              + '--dur:' + fDur + 's;--delay:' + fDelay + 's;"></span>';
                    }
                    bg.innerHTML = html;
                    document.documentElement.insertBefore(bg, document.body);
                })();

                // --- GAME OVER volant + mini-jeu "attrape-la" (clic = +1) ---
                (function buildFlyingGameOver() {
                    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

                    var img = document.createElement('img');
                    img.src = '/img/game-over.png';
                    img.alt = 'Attrape le game over !';
                    img.title = 'Attrape-moi !';
                    img.id = 'flying-gameover';
                    img.style.cssText = [
                        'position:fixed', 'top:0', 'left:0', 'z-index:40',
                        'width:150px', 'height:auto', 'pointer-events:auto', 'cursor:crosshair',
                        'filter:drop-shadow(0 0 14px rgba(57,255,20,0.55))',
                        'will-change:transform', 'user-select:none', '-webkit-user-drag:none'
                    ].join(';');
                    document.documentElement.appendChild(img);

                    // Petit HUD de score
                    var hud = document.createElement('div');
                    hud.id = 'gameover-score';
                    hud.style.cssText = [
                        'position:fixed', 'top:84px', 'left:16px', 'z-index:41', 'pointer-events:none',
                        'font-family:Inter,sans-serif', 'background:rgba(10,10,10,0.7)',
                        'border:1px solid rgba(57,255,20,0.4)', 'border-radius:12px',
                        'padding:6px 12px', 'box-shadow:0 0 20px rgba(57,255,20,0.25)',
                        'backdrop-filter:blur(4px)'
                    ].join(';');
                    hud.innerHTML = '<div style="font-size:8px;letter-spacing:0.25em;color:#b794f4;text-transform:uppercase;font-weight:800;">Mika attrapés</div>'
                                  + '<div style="font-size:22px;color:#39ff14;font-weight:900;text-shadow:0 0 10px rgba(57,255,20,0.6);line-height:1;" id="gameover-count">0</div>';
                    document.documentElement.appendChild(hud);
                    var countEl = document.getElementById('gameover-count');

                    var W = 150, H = 109; // ratio ~500x363
                    var x = Math.random() * Math.max(0, window.innerWidth - W);
                    var y = Math.random() * Math.max(0, window.innerHeight - H);
                    var speed = 4;  // facteur de vitesse, augmente à chaque capture
                    var vx = (Math.random() * 2 + 1) * (Math.random() < 0.5 ? -1 : 1);
                    var vy = (Math.random() * 2 + 1) * (Math.random() < 0.5 ? -1 : 1);
                    var rot = 0;
                    var vrot = (Math.random() * 4 - 2);
                    var t = 0;
                    var score = parseInt(sessionStorage.getItem('gameoverScore') || '0', 10);
                    countEl.textContent = score;

                    function teleport() {
                        x = Math.random() * Math.max(0, window.innerWidth - W);
                        y = Math.random() * Math.max(0, window.innerHeight - H);
                        var ang = Math.random() * Math.PI * 2;
                        vx = Math.cos(ang); vy = Math.sin(ang);
                    }

                    function spawnPlus(px, py) {
                        var s = document.createElement('div');
                        s.textContent = '+1';
                        s.style.cssText = 'position:fixed;left:' + px + 'px;top:' + py + 'px;z-index:42;'
                            + 'color:#39ff14;font-family:Inter,sans-serif;font-weight:900;font-size:24px;'
                            + 'text-shadow:0 0 10px rgba(57,255,20,0.8);pointer-events:none;'
                            + 'transition:transform 0.7s ease-out,opacity 0.7s ease-out;';
                        document.documentElement.appendChild(s);
                        requestAnimationFrame(function () {
                            s.style.transform = 'translateY(-40px) scale(1.4)';
                            s.style.opacity = '0';
                        });
                        setTimeout(function () { s.remove(); }, 750);
                    }

                    img.addEventListener('click', function (e) {
                        score += 1;
                        sessionStorage.setItem('gameoverScore', String(score));
                        countEl.textContent = score;
                        spawnPlus(e.clientX - 10, e.clientY - 20);
                        // effet "écrasé" puis téléportation + accélération
                        speed = Math.min(14, speed + 0.8);
                        img.style.transition = 'transform 0.12s ease-out';
                        img.style.transform += ' scale(0.6)';
                        // petit flash de score milestone
                        if (score % 10 === 0) {
                            hud.animate([{ transform: 'scale(1)' }, { transform: 'scale(1.3)' }, { transform: 'scale(1)' }], { duration: 400 });
                        }
                        setTimeout(function () { img.style.transition = ''; teleport(); }, 120);
                    });

                    function frame() {
                        t += 1;
                        if (t % 45 === 0) {
                            vx += (Math.random() * 2 - 1) * 0.6;
                            vy += (Math.random() * 2 - 1) * 0.6;
                            vrot = (Math.random() * 8 - 4);
                            // normalise la direction (on garde une vitesse ~constante via 'speed')
                            var m = Math.hypot(vx, vy) || 1;
                            vx /= m; vy /= m;
                        }
                        rot += vrot;
                        var maxX = window.innerWidth - W;
                        var maxY = window.innerHeight - H;
                        x += vx * speed; y += vy * speed;

                        if (x < 0)    { x = 0;    vx = Math.abs(vx); vrot = (Math.random()*8-4); }
                        if (x > maxX) { x = maxX; vx = -Math.abs(vx); vrot = (Math.random()*8-4); }
                        if (y < 0)    { y = 0;    vy = Math.abs(vy); vrot = (Math.random()*8-4); }
                        if (y > maxY) { y = maxY; vy = -Math.abs(vy); vrot = (Math.random()*8-4); }

                        img.style.transform = 'translate(' + x + 'px,' + y + 'px) rotate(' + rot + 'deg)';
                        requestAnimationFrame(frame);
                    }
                    requestAnimationFrame(frame);

                    window.addEventListener('resize', function () {
                        x = Math.min(x, Math.max(0, window.innerWidth - W));
                        y = Math.min(y, Math.max(0, window.innerHeight - H));
                    });
                })();

                // --- Construire le lecteur UNE seule fois, hors du <body> ---
                var host = document.createElement('div');
                host.id = 'player-permanent';
                host.innerHTML = [
                    '<div id="sc-player-bar" class="fixed bottom-0 left-0 right-0 z-[9999] bg-primary/95 backdrop-blur border-t border-accent/40 shadow-[0_-4px_30px_rgba(0,0,0,0.5)] transition-transform duration-300" style="font-family:Inter,sans-serif;">',
                    '  <div class="max-w-6xl mx-auto px-3 md:px-6 py-2.5 flex items-center gap-3 md:gap-4">',
                    '    <button id="sc-toggle" aria-label="Lecture / Pause" class="shrink-0 w-10 h-10 rounded-full bg-accent text-primary flex items-center justify-center text-lg font-black hover:scale-105 transition-transform shadow-[0_0_15px_rgba(57,255,20,0.4)]"><span id="sc-toggle-icon">▶</span></button>',
                    '    <div class="flex-1 min-w-0">',
                    '      <div class="flex items-center justify-between gap-2 mb-1">',
                    '        <span id="sc-title" class="truncate text-[11px] md:text-xs font-bold uppercase tracking-wide text-white">J’arrive en Tesla</span>',
                    '        <span id="sc-time" class="shrink-0 text-[10px] font-mono text-mauve-light tabular-nums">0:00</span>',
                    '      </div>',
                    '      <div id="sc-progress-track" class="h-1.5 w-full bg-white/10 rounded-full cursor-pointer overflow-hidden"><div id="sc-progress" class="h-full w-0 bg-accent rounded-full"></div></div>',
                    '    </div>',
                    '    <input id="sc-volume" type="range" min="0" max="100" value="80" class="hidden sm:block w-20 cursor-pointer" style="accent-color:#39ff14" aria-label="Volume">',
                    '    <button id="sc-hide" aria-label="Masquer le lecteur" class="shrink-0 w-8 h-8 rounded-full text-mauve-light hover:text-accent hover:bg-white/5 transition-colors flex items-center justify-center text-sm">✕</button>',
                    '  </div>',
                    '  <iframe id="sc-widget" title="Lecteur SoundCloud" width="100%" height="0" frameborder="no" allow="autoplay" style="display:none" src="https://w.soundcloud.com/player/?url=https%3A%2F%2Fsoundcloud.com%2Fpuanteurputride%2Fjarrive-en-tesla&color=%2339ff14&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false&visual=false"></iframe>',
                    '</div>',
                    '<button id="sc-show" aria-label="Afficher le lecteur" class="hidden fixed bottom-4 right-4 z-[9999] w-12 h-12 rounded-full bg-accent text-primary text-xl shadow-[0_0_20px_rgba(57,255,20,0.5)] hover:scale-105 transition-transform">🎵</button>'
                ].join('');
                // Attaché à <html>, PAS à <body> -> Turbo n'y touche jamais.
                document.documentElement.appendChild(host);

                var iframe   = document.getElementById('sc-widget');
                if (!iframe || typeof SC === 'undefined') return;

                var widget      = SC.Widget(iframe);
                var bar         = document.getElementById('sc-player-bar');
                var toggleBtn   = document.getElementById('sc-toggle');
                var toggleIcon  = document.getElementById('sc-toggle-icon');
                var titleEl     = document.getElementById('sc-title');
                var timeEl      = document.getElementById('sc-time');
                var progressEl  = document.getElementById('sc-progress');
                var trackEl     = document.getElementById('sc-progress-track');
                var volumeEl    = document.getElementById('sc-volume');
                var hideBtn     = document.getElementById('sc-hide');
                var showBtn     = document.getElementById('sc-show');

                var isPlaying = false;
                var duration  = 0;

                function fmt(ms) {
                    var s = Math.floor((ms || 0) / 1000);
                    var m = Math.floor(s / 60);
                    s = s % 60;
                    return m + ':' + (s < 10 ? '0' : '') + s;
                }
                function setIcon(playing) {
                    toggleIcon.textContent = playing ? '❚❚' : '▶';
                }

                widget.bind(SC.Widget.Events.READY, function () {
                    widget.setVolume(parseInt(volumeEl.value, 10));
                    widget.getDuration(function (d) { duration = d; });
                    widget.getCurrentSound(function (sound) {
                        if (sound && sound.title) titleEl.textContent = sound.title;
                    });

                    // Tentative de lecture auto (souvent bloquée par le navigateur tant
                    // qu'il n'y a pas eu d'interaction — on retombe alors sur le bouton play).
                    widget.play();

                    // Si l'autoplay est bloqué, on démarre au tout premier clic/touche sur la page.
                    var kick = function () {
                        if (!isPlaying) widget.play();
                        document.removeEventListener('click', kick);
                        document.removeEventListener('keydown', kick);
                        document.removeEventListener('touchstart', kick);
                    };
                    document.addEventListener('click', kick);
                    document.addEventListener('keydown', kick);
                    document.addEventListener('touchstart', kick);
                });

                widget.bind(SC.Widget.Events.PLAY,  function () { isPlaying = true;  setIcon(true);  });
                widget.bind(SC.Widget.Events.PAUSE, function () { isPlaying = false; setIcon(false); });

                // Fin du morceau -> on reboucle au début.
                widget.bind(SC.Widget.Events.FINISH, function () {
                    widget.seekTo(0);
                    widget.play();
                });

                widget.bind(SC.Widget.Events.PLAY_PROGRESS, function (e) {
                    if (!duration) { widget.getDuration(function (d) { duration = d; }); return; }
                    var pct = Math.min(100, (e.currentPosition / duration) * 100);
                    progressEl.style.width = pct + '%';
                    timeEl.textContent = fmt(e.currentPosition);
                });

                toggleBtn.addEventListener('click', function () {
                    widget.isPaused(function (paused) { paused ? widget.play() : widget.pause(); });
                });

                volumeEl.addEventListener('input', function () {
                    widget.setVolume(parseInt(volumeEl.value, 10));
                });

                // Clic sur la barre de progression -> déplacement dans le morceau
                trackEl.addEventListener('click', function (ev) {
                    if (!duration) return;
                    var rect = trackEl.getBoundingClientRect();
                    var ratio = (ev.clientX - rect.left) / rect.width;
                    widget.seekTo(Math.max(0, Math.min(1, ratio)) * duration);
                });

                // Masquer / réafficher la barre (la musique continue de jouer)
                hideBtn.addEventListener('click', function () {
                    bar.style.transform = 'translateY(110%)';
                    showBtn.classList.remove('hidden');
                });
                showBtn.addEventListener('click', function () {
                    bar.style.transform = '';
                    showBtn.classList.add('hidden');
                });
            })();
        </script>
    </body>
</html>
