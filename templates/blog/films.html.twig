{% extends 'base.html.twig' %}

{% block title %}Les Films - Imm🧅nde Plus | Archives Vidéos{% endblock %}

{% block body %}
    <div class="border-b-2 border-accent pb-8 mb-12">
        <h1 class="font-mystere text-5xl tracking-widest text-accent italic uppercase text-shadow-[0_0_15px_rgba(57,255,20,0.5)]">Le Cinéma de l'Étrange</h1>
        <p class="text-mauve-light mt-2 font-bold uppercase text-[10px] tracking-[0.3em]">Tous les films de Mickael Emond, en accès direct.</p>
    </div>

    <div class="mb-20 text-center relative group">
        <div class="absolute -inset-2 bg-accent/5 blur-xl rounded-full opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
        <div class="relative">
            <input type="text" id="film-search" name="q" value="{{ searchTerm }}" placeholder="FILTRER LES PELLICULES..." 
                class="w-full max-w-2xl bg-white/5 border-2 border-white/10 focus:border-accent focus:bg-accent/5 focus:ring-4 focus:ring-accent/10 rounded-full px-10 py-6 text-white font-black placeholder:text-white/20 transition-all text-xl text-center uppercase tracking-widest shadow-2xl">
            <div class="absolute right-12 top-1/2 -translate-y-1/2 text-accent/30 animate-pulse hidden md:block">
                <span class="text-[10px] font-black tracking-tighter">V1.0-MEDIA</span>
            </div>
        </div>
    </div>

    <div id="films-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-12 gap-y-16 transition-opacity duration-300 text-white">
        
        {# Affichage des Séries (Dossiers) #}
        {% for s in series %}
            {% set isNew = false %}
            {% for film in s.films|filter(f => f.isPublished) %}
                {% if date(film.publishedAt) > date('-3 days') %}
                    {% set isNew = true %}
                {% endif %}
            {% endfor %}

            <a href="{{ path('blog_series_show', {slug: s.slug}) }}" class="group flex flex-col items-center text-center relative">
                {% if isNew %}
                    <div class="absolute -top-4 -left-4 z-50 bg-accent text-primary text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-[0_0_15px_rgba(57,255,20,0.6)] animate-pulse rotate-[-15deg] border-2 border-primary">
                        Nouveau
                    </div>
                {% endif %}
                
                <div class="relative w-32 h-24 md:w-40 md:h-32 mb-6">
                    {# Modernized macOS style folder structure #}
                    <div class="absolute inset-0 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 shadow-xl transition-all duration-500 group-hover:bg-accent/10 group-hover:border-accent/40 group-hover:scale-105 group-hover:-rotate-2">
                        {# Tab of the folder #}
                        <div class="absolute -top-2.5 left-0 w-12 h-3 bg-white/5 rounded-t-lg border-x border-t border-white/10 group-hover:bg-accent/10 group-hover:border-accent/40"></div>
                        
                        {# Folder Image Preview #}
                        <div class="absolute inset-2 overflow-hidden rounded-xl bg-black/40 border border-white/5 group-hover:border-accent/10">
                            {% if s.image %}
                                <img src="{{ asset('uploads/films/' ~ s.image) }}" alt="{{ s.title }}" class="w-full h-full object-cover opacity-50 group-hover:opacity-100 transition-opacity duration-500">
                            {% else %}
                                <div class="w-full h-full flex items-center justify-center text-accent/20 font-mystere text-xl">?</div>
                            {% endif %}
                        </div>
                    </div>
                    {# Badge with number of films #}
                    <div class="absolute -top-2 -right-2 bg-accent text-primary text-[9px] font-black px-2 py-0.5 rounded-full shadow-[0_0_10px_rgba(57,255,20,0.4)] z-30">
                        {{ s.films|filter(f => f.isPublished)|length }}
                    </div>
                </div>
                <h2 class="font-mystere text-xl leading-tight group-hover:text-accent transition-colors tracking-widest italic uppercase">
                    {{ s.title }}
                </h2>
                <span class="text-[9px] font-black uppercase text-mauve-light tracking-tighter opacity-50 mt-1">Série</span>
            </a>
        {% endfor %}

        {# Affichage des Films Indépendants #}
        {% for film in standaloneFilms %}
            <article class="flex flex-col group items-center text-center relative">
                {% if date(film.publishedAt) > date('-3 days') %}
                    <div class="absolute -top-4 -left-4 z-50 bg-accent text-primary text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-[0_0_15px_rgba(57,255,20,0.6)] animate-pulse rotate-[-15deg] border-2 border-primary">
                        Nouveau
                    </div>
                {% endif %}

                <a href="{{ path('film_show', {slug: film.slug}) }}" class="block mb-6 relative w-32 h-44 md:w-40 md:h-56 overflow-hidden rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.6)] border border-white/10 group-hover:border-accent/50 transition-all duration-500 group-hover:scale-105 group-hover:rotate-1">
                    {% if film.image %}
                        <img src="{{ asset('uploads/films/' ~ film.image) }}" alt="{{ film.title }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                    {% else %}
                        <div class="w-full h-full bg-white/5 flex items-center justify-center text-2xl opacity-20 transition-opacity group-hover:opacity-40 text-accent font-mystere italic tracking-tighter uppercase">Film</div>
                    {% endif %}
                    
                    {# Overlay on hover #}
                    <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center p-4">
                        <span class="text-accent font-black uppercase text-[9px] tracking-widest border border-accent/40 px-3 py-1.5 rounded-full bg-accent/5 backdrop-blur-sm">Visionner</span>
                    </div>

                    {# Scanning Line Effect #}
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
                        <div class="absolute top-0 left-0 w-full h-[2px] bg-accent/50 shadow-[0_0_15px_#39ff14] animate-scan"></div>
                    </div>
                </a>

                <h2 class="font-mystere text-xl leading-tight mb-2 group-hover:text-accent transition-colors tracking-widest italic uppercase">
                    <a href="{{ path('film_show', {slug: film.slug}) }}">{{ film.title }}</a>
                </h2>
                <time class="text-[9px] font-black uppercase text-mauve-light tracking-tighter opacity-50">Diffusé le {{ film.publishedAt|date('d/m/Y') }}</time>
            </article>
        {% endfor %}

        {% if series|length == 0 and standaloneFilms|length == 0 %}
            <div class="text-center py-32 col-span-full border-2 border-dashed border-white/5 rounded-[3rem]">
                <p class="text-mauve-light font-black italic uppercase tracking-[0.4em] opacity-40">Aucun film correspondant à cette recherche.</p>
            </div>
        {% endif %}
    </div>

    <script>
        const searchInput = document.getElementById('film-search');
        const grid = document.getElementById('films-grid');
        let searchTimeout;

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value;
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                grid.style.opacity = '0.3';
                const url = new URL(window.location.href);
                if (query) {
                    url.searchParams.set('q', query);
                } else {
                    url.searchParams.delete('q');
                }
                window.location.href = url.toString();
            }, 600);
        });

        if (searchInput.value) {
            searchInput.focus();
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
        }
    </script>
{% endblock %}
