        <script>
            // Menu burger mobile
            (function() {
                if (window.navLogicInitialized) return;

                const handleBurger = () => {
                    const burgerBtn = document.getElementById('burger-menu-btn');
                    const overlay = document.getElementById('mobile-menu-overlay');
                    const icon = document.getElementById('burger-icon');
                    const mobileLinks = document.querySelectorAll('.mobile-link');

                    if (!burgerBtn || !overlay || burgerBtn.hasAttribute('data-listener-added')) return;

                    const closeMenu = () => {
                        overlay.classList.remove('translate-x-0');
                        overlay.classList.add('translate-x-full');
                        icon.textContent = '☰';
                        document.body.style.overflow = '';
                    };

                    const toggleMenu = () => {
                        const isOpen = overlay.classList.contains('translate-x-0');
                        if (isOpen) {
                            closeMenu();
                        } else {
                            overlay.classList.remove('translate-x-full');
                            overlay.classList.add('translate-x-0');
                            icon.textContent = '✕';
                            document.body.style.overflow = 'hidden';
                        }
                    };

                    burgerBtn.addEventListener('click', toggleMenu);
                    mobileLinks.forEach(link => link.addEventListener('click', closeMenu));
                    burgerBtn.setAttribute('data-listener-added', 'true');
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', handleBurger);
                } else {
                    handleBurger();
                }
                document.addEventListener('turbo:load', handleBurger);

                window.navLogicInitialized = true;
            })();
        </script>
    </head>
