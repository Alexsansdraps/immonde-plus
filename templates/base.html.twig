            <div class="bg-black/85 backdrop-blur border-l-4 border-accent rounded-r-xl px-4 py-3 shadow-[0_0_30px_rgba(57,255,20,0.3)]">
                <div class="text-[8px] tracking-[0.3em] text-accent uppercase font-black mb-1">🟢 BAVE ÉCRASÉE</div>
                <div id="slime-msg" class="text-[11px] text-mauve-light font-bold uppercase tracking-wider leading-snug"></div>
            </div>
        </div>

        <style>
            @keyframes misere-fly {
                0%   { transform: translate(0,0) rotate(0deg); }
                25%  { transform: translate(40px,-30px) rotate(20deg); }
                50%  { transform: translate(-25px,20px) rotate(-15deg); }
                75%  { transform: translate(30px,35px) rotate(10deg); }
                100% { transform: translate(0,0) rotate(0deg); }
            }
            .misere-fly {
                position: fixed;
                z-index: 9997;
                pointer-events: none;
                font-size: 18px;
                opacity: 0.85;
                will-change: transform;
                filter: drop-shadow(0 0 3px rgba(0,0,0,0.6));
            }
            @keyframes slime-drip {
                0%   { transform: translateY(0) scaleY(1); opacity: 0.9; }
                70%  { opacity: 0.9; }
                100% { transform: translateY(45px) scaleY(1.8); opacity: 0; }
            }
            .slime-drip {
                position: fixed;
                z-index: 9996;
                pointer-events: none;
                width: 7px; height: 7px;
                border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
                background: radial-gradient(circle at 30% 30%, #7dff5c, #39ff14 60%, #2bbf0e);
                box-shadow: 0 0 8px rgba(57,255,20,0.7);
                animation: slime-drip 1.1s ease-in forwards;
            }
            @keyframes global-glitch {
                0%,100% { filter: none; transform: none; }
                20% { filter: hue-rotate(40deg) saturate(2); transform: translate(-2px,1px) skewX(0.6deg); }
                40% { filter: invert(0.04) hue-rotate(-30deg); transform: translate(3px,-2px); }
                60% { filter: contrast(1.3); transform: translate(-1px,2px) skewY(0.4deg); }
                80% { filter: hue-rotate(20deg); transform: translate(2px,0); }
            }
            body.misere-glitch { animation: global-glitch 0.45s steps(2) 2; }

            /* ---- Slime fugitif ---- */
            #slime-fugitif {
                position: fixed;
                z-index: 9995;
                width: 64px; height: 64px;
                pointer-events: none;
                will-change: transform;
                filter: drop-shadow(0 6px 6px rgba(0,0,0,0.5));
                transition: opacity 0.25s;
            }
            #slime-fugitif.attrape { animation: slime-squish 0.35s ease-out; }
            @keyframes slime-squish {
                0%   { transform: scale(1,1); }
                40%  { transform: scale(1.5,0.45); }
                70%  { transform: scale(0.7,1.3); }
                100% { transform: scale(0,0); opacity: 0; }
            }
            @keyframes splat-fly {
                0%   { transform: translate(0,0) scale(1); opacity: 1; }
                100% { transform: translate(var(--dx), var(--dy)) scale(0.2); opacity: 0; }
            }
            .splat-blob {
                position: fixed;
                z-index: 9994;
                pointer-events: none;
                border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
                background: radial-gradient(circle at 30% 30%, #9dff7a, #39ff14 60%, #1f8f08);
                box-shadow: 0 0 10px rgba(57,255,20,0.7);
                animation: splat-fly 0.9s cubic-bezier(0.2,0.7,0.3,1) forwards;
            }
            @media (pointer: fine) and (min-width: 768px) {
                body, body.font-sans { cursor: var(--slime-cursor), auto !important; }
                a, button, [role="button"], input, textarea, select, label {
                    cursor: var(--slime-cursor), pointer !important;
                }
            }
        </style>

        <script>
            (function () {
                if (window.misereEngineInitialized) return;
                window.misereEngineInitialized = true;

                const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                /* ---- Indice de Misère : ne fait que grimper ---- */
                const counterEl = document.getElementById('misere-count');
                const labelEl   = document.getElementById('misere-label');
                const PALIERS = [
                    [0,    'Contamination en cours…'],
                    [120,  'Odeur détectée'],
                    [300,  'Niveau préoccupant'],
                    [600,  'Trognon exposé'],
                    [999,  'IMMONDITUDE MAXIMALE'],
                ];
                let misere = parseInt(sessionStorage.getItem('misere') || '0', 10);
                function renderMisere() {
                    if (!counterEl) return;
                    counterEl.textContent = misere;
                    let label = PALIERS[0][1];
                    for (const [seuil, txt] of PALIERS) if (misere >= seuil) label = txt;
                    if (labelEl) labelEl.textContent = label;
                }
                function bumpMisere(n) {
                    misere = Math.min(999, misere + n);
                    sessionStorage.setItem('misere', String(misere));
                    renderMisere();
                }
                renderMisere();
                if (!reduce) setInterval(() => bumpMisere(1), 1800);

                /* ---- Goutte de bave qui suit le curseur ---- */
                let lastDrip = 0;
                if (!reduce) document.addEventListener('mousemove', (e) => {
                    const now = e.timeStamp;
                    if (now - lastDrip < 90) return;
                    lastDrip = now;
                    const d = document.createElement('div');
                    d.className = 'slime-drip';
                    d.style.left = (e.clientX - 3) + 'px';
                    d.style.top  = (e.clientY + 4) + 'px';
                    document.body.appendChild(d);
                    setTimeout(() => d.remove(), 1100);
                });

                /* ---- Essaim de mouches ---- */
                function spawnFlies(count) {
                    for (let i = 0; i < count; i++) {
                        const f = document.createElement('div');
                        f.className = 'misere-fly';
                        f.textContent = Math.random() > 0.5 ? '🪰' : '🦟';
                        f.style.left = Math.random() * 90 + 'vw';
                        f.style.top  = Math.random() * 80 + 'vh';
                        f.style.animation = `misere-fly ${4 + Math.random() * 5}s ease-in-out ${Math.random() * 3}s infinite`;
                        f.style.fontSize = (12 + Math.random() * 14) + 'px';
                        document.body.appendChild(f);
                    }
                }
                if (!reduce) spawnFlies(window.innerWidth < 768 ? 3 : 7);

                /* ---- Toast réutilisé pour le cri du slime ---- */
                const toast = document.getElementById('slime-toast');
                const toastMsg = document.getElementById('slime-msg');

                /* ---- Larmes d'oignon : glitch + vignette occasionnels ---- */
                const tears = document.getElementById('onion-tears');
                function onionTear() {
                    if (reduce) return;
                    document.body.classList.add('misere-glitch');
                    if (tears) tears.style.opacity = '1';
                    bumpMisere(8);
                    setTimeout(() => {
                        document.body.classList.remove('misere-glitch');
                        if (tears) tears.style.opacity = '0';
                    }, 900);
                }
                if (!reduce) setInterval(onionTear, 23000);

                /* ---- La bave : mascotte SVG réutilisable ---- */
                function slimeSVG(size, sad) {
                    const mouth = sad
                        ? "<path d='M36 70 Q50 60 64 70' stroke='%230a3d02' stroke-width='3.5' fill='none' stroke-linecap='round'/>"
                        : "<path d='M38 64 Q50 76 62 64' stroke='%230a3d02' stroke-width='3.5' fill='none' stroke-linecap='round'/>";
                    return "<svg xmlns='http://www.w3.org/2000/svg' width='" + size + "' height='" + size + "' viewBox='0 0 100 100'>"
                        + "<defs><radialGradient id='sg' cx='35%25' cy='28%25'>"
                        + "<stop offset='0%25' stop-color='%239dff7a'/><stop offset='55%25' stop-color='%2339ff14'/><stop offset='100%25' stop-color='%231f8f08'/>"
                        + "</radialGradient></defs>"
                        + "<path d='M50 8 C76 8 91 28 91 51 C91 69 96 78 92 88 C89 95 84 88 79 90 C74 92 73 84 67 86 C61 88 59 97 51 96 C45 95 45 86 39 87 C33 88 31 97 25 92 C19 87 24 79 20 75 C12 67 9 59 9 50 C9 27 24 8 50 8 Z' fill='url(%23sg)'/>"
                        + "<ellipse cx='37' cy='30' rx='11' ry='7' fill='%23ffffff' opacity='0.45'/>"
                        + "<circle cx='40' cy='46' r='8.5' fill='%23fff'/><circle cx='62' cy='46' r='8.5' fill='%23fff'/>"
                        + "<circle cx='41' cy='49' r='4.2' fill='%23000'/><circle cx='63' cy='49' r='4.2' fill='%23000'/>"
                        + (sad ? "<path d='M37 58 Q40 67 36 72' stroke='%23a8e6ff' stroke-width='2.5' fill='none' opacity='0.8'/>" : "")
                        + mouth + "</svg>";
                }

                /* Curseur slime (desktop pointeur fin uniquement) */
                const fine = window.matchMedia('(pointer: fine)').matches && window.innerWidth >= 768;
                if (fine) {
                    const curUri = "data:image/svg+xml," + slimeSVG(36, true);
                    document.documentElement.style.setProperty('--slime-cursor', "url(\"" + curUri + "\") 18 18");
                }

                /* Slime fugitif et misérable */
                if (fine && !reduce) {
                    const sprite = document.createElement('img');
                    sprite.id = 'slime-fugitif';
                    sprite.alt = 'bave fugitive';
                    sprite.src = "data:image/svg+xml," + slimeSVG(64, true);
                    document.body.appendChild(sprite);

                    const mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
                    document.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });

                    const S = { x: Math.random() * window.innerWidth, y: Math.random() * window.innerHeight,
                                vx: 0, vy: 0, tx: 0, ty: 0, t: 0, caught: false };
                    function pickTarget() {
                        S.tx = 40 + Math.random() * (window.innerWidth - 80);
                        S.ty = 40 + Math.random() * (window.innerHeight - 80);
                    }
                    pickTarget();
                    setInterval(() => { if (!S.caught) pickTarget(); }, 2600);

                    const CRIS = [
                        "SPLOURTCH !", "Tu m'as eu… encore.", "Je suis si misérable 😭",
                        "Laisse-moi suinter en paix !", "BLEUARGH.", "Pourquoi moi…",
                        "*bruit de pelure mouillée*", "Aïe, ma gélatine !",
                    ];
                    let dripT = 0, crisIdx = 0;

                    function splat(x, y) {
                        for (let i = 0; i < 16; i++) {
                            const b = document.createElement('div');
                            b.className = 'splat-blob';
                            const sz = 6 + Math.random() * 16;
                            b.style.width = sz + 'px'; b.style.height = sz + 'px';
                            b.style.left = (x - sz / 2) + 'px';
                            b.style.top  = (y - sz / 2) + 'px';
                            const ang = Math.random() * Math.PI * 2, dist = 50 + Math.random() * 140;
                            b.style.setProperty('--dx', Math.cos(ang) * dist + 'px');
                            b.style.setProperty('--dy', (Math.sin(ang) * dist + 60) + 'px');
                            document.body.appendChild(b);
                            setTimeout(() => b.remove(), 950);
                        }
                    }

                    function catchSlime() {
                        if (S.caught) return;
                        S.caught = true;
                        sprite.classList.add('attrape');
                        splat(S.x + 32, S.y + 32);
                        bumpMisere(50);
                        if (toast && toastMsg) {
                            toastMsg.textContent = CRIS[crisIdx++ % CRIS.length];
                            toast.classList.remove('translate-x-[120%]');
                            setTimeout(() => toast.classList.add('translate-x-[120%]'), 3000);
                        }
                        document.body.classList.add('misere-glitch');
                        setTimeout(() => document.body.classList.remove('misere-glitch'), 450);
                        setTimeout(() => {
                            sprite.classList.remove('attrape');
                            S.x = Math.random() > 0.5 ? -60 : window.innerWidth + 60;
                            S.y = Math.random() * window.innerHeight;
                            S.vx = S.vy = 0;
                            pickTarget();
                            sprite.style.opacity = '1';
                            S.caught = false;
                        }, 1400);
                    }

                    function tick(now) {
                        if (!S.caught) {
                            S.t += 0.05;
                            const dxm = (S.x + 32) - mouse.x, dym = (S.y + 32) - mouse.y;
                            const distM = Math.hypot(dxm, dym);

                            if (distM < 95) { catchSlime(); }
                            else {
                                let ax, ay;
                                if (distM < 230) {            // panique : fuit le curseur
                                    ax = (dxm / distM) * 0.9;
                                    ay = (dym / distM) * 0.9;
                                } else {                       // errance molle vers une cible
                                    const dxt = S.tx - S.x, dyt = S.ty - S.y;
                                    const dt = Math.hypot(dxt, dyt) || 1;
                                    ax = (dxt / dt) * 0.12;
                                    ay = (dyt / dt) * 0.12;
                                }
                                S.vx = S.vx * 0.92 + ax;
                                S.vy = S.vy * 0.92 + ay + 0.03;           // un peu de gravité = ça s'affaisse
                                S.vx += Math.sin(S.t * 1.7) * 0.10;       // dandinement misérable
                                S.x += S.vx;
                                S.y += S.vy;

                                // rebonds mous sur les bords
                                if (S.x < 0) { S.x = 0; S.vx = Math.abs(S.vx) * 0.6; }
                                if (S.x > window.innerWidth - 64) { S.x = window.innerWidth - 64; S.vx = -Math.abs(S.vx) * 0.6; }
                                if (S.y < 0) { S.y = 0; S.vy = Math.abs(S.vy) * 0.6; }
                                if (S.y > window.innerHeight - 64) { S.y = window.innerHeight - 64; S.vy = -Math.abs(S.vy) * 0.4; }

                                const tilt = Math.max(-18, Math.min(18, S.vx * 4));
                                sprite.style.transform = "translate(" + S.x + "px," + S.y + "px) rotate(" + tilt + "deg) scaleY(" + (1 - Math.min(0.2, Math.abs(S.vy) * 0.05)) + ")";

                                // laisse une traînée de bave
                                if (now - dripT > 130) {
                                    dripT = now;
                                    const d = document.createElement('div');
                                    d.className = 'slime-drip';
                                    d.style.left = (S.x + 28) + 'px';
                                    d.style.top  = (S.y + 50) + 'px';
                                    document.body.appendChild(d);
                                    setTimeout(() => d.remove(), 1100);
                                }
                            }
                        }
                        requestAnimationFrame(tick);
                    }
                    requestAnimationFrame(tick);
                }
            })();
        </script>
    </body>
</html>
