{% extends 'base.html.twig' %}

{% block title %}{{ film.title }} - Immonde Plus | Projection Exclusive{% endblock %}

{% block body %}
    <article class="max-w-4xl mx-auto text-white relative">
        {% if is_granted('ROLE_ADMIN') %}
            <div class="absolute -top-8 right-0 flex justify-end z-[100]">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\FilmCrudController').setAction('edit').setEntityId(film.id) }}" class="bg-accent text-primary px-4 py-1 rounded-full font-black text-[9px] uppercase shadow-[0_0_15px_rgba(57,255,20,0.4)] hover:scale-105 transition-all">
                    ✎ Modifier le film
                </a>
            </div>
        {% endif %}
        
        <header class="text-center mb-12">
            <div class="text-accent font-black uppercase tracking-[0.4em] text-[12px] mb-4 italic">
                PROJECTION EXCLUSIVE : CLASSIFIÉ
            </div>
            <h1 class="font-mystere text-4xl md:text-7xl text-accent leading-tight mb-6 italic tracking-widest uppercase drop-shadow-[0_5px_20px_rgba(57,255,20,0.4)]">{{ film.title }}</h1>
            <div class="flex items-center justify-center gap-4 text-sm text-mauve-light font-bold uppercase tracking-tighter">
                <span class="w-2 h-2 bg-accent rounded-full animate-ping"></span>
                <time>Date de sortie : {{ film.publishedAt|date('d/m/Y') }}</time>
            </div>
        </header>

        <div class="mb-12 shadow-[0_0_60px_rgba(0,0,0,0.9)] rounded-xl overflow-hidden bg-black border-4 border-mauve-dark group hover:border-accent transition-all duration-500">
            {% if film.videoFile %}
                <video controls class="w-full h-auto bg-black" poster="{{ film.image ? asset('uploads/films/' ~ film.image) : '' }}">
                    <source src="{{ asset('videos/' ~ film.videoFile) }}" type="video/mp4">
                    Votre navigateur ne supporte pas la lecture de vidéos.
                </video>
            {% elseif film.videoUrl %}
                {% if 'youtube.com' in film.videoUrl or 'youtu.be' in film.videoUrl or 'infomaniak.com' in film.videoUrl %}
                    <div class="relative pb-[56.25%] h-0">
                        <iframe class="absolute top-0 left-0 w-full h-full border-0" src="{{ film.videoUrl }}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                    </div>
                {% else %}
                    <video controls class="w-full h-auto bg-black" poster="{{ film.image ? asset('uploads/films/' ~ film.image) : '' }}">
                        <source src="{{ film.videoUrl }}" type="video/mp4">
                        Votre navigateur ne supporte pas la lecture de vidéos.
                    </video>
                {% endif %}
            {% endif %}
        </div>

        <div class="max-w-2xl mx-auto">
            <div class="border-l-4 border-accent pl-6 py-4 mb-12 bg-mauve-dark/10 rounded-r-lg border-dashed">
                <h2 class="font-mystere text-3xl italic uppercase tracking-tighter mb-4 text-accent">Le Synopsis</h2>
                <div class="text-gray-200 leading-relaxed font-medium italic text-lg">
                    {{ film.description|nl2br }}
                </div>
            </div>

            <div class="mt-20 text-center border-t border-mauve-dark/30 pt-12">
                <a href="{{ path('blog_films') }}" class="inline-flex items-center gap-4 text-accent font-black uppercase text-xs tracking-[0.3em] hover:scale-110 transition-all group">
                    <span class="text-2xl group-hover:-translate-x-2 transition-transform">←</span> Retour au catalogue des archives
                </a>
            </div>
        </div>
    </article>
{% endblock %}
