{% extends 'base.html.twig' %}

{% block title %}{{ article.metaTitle ?: article.title ~ ' | Immonde Plus' }}{% endblock %}
{% block meta_description %}{{ article.metaDescription ?: article.summary|striptags|slice(0, 160) }}{% endblock %}

{% block og_image %}
    {% if article.image %}
        {{ absolute_url(asset('uploads/articles/' ~ article.image)) }}
    {% endif %}
{% endblock %}

{% block body %}
    <article class="max-w-4xl mx-auto relative">
        {% if is_granted('ROLE_ADMIN') %}
            <div class="absolute -top-8 right-0 flex justify-end z-[100]">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ArticleCrudController').setAction('edit').setEntityId(article.id) }}" class="bg-accent text-primary px-4 py-1 rounded-full font-black text-[9px] uppercase shadow-[0_0_15px_rgba(57,255,20,0.4)] hover:scale-105 transition-all">
                    ✎ Modifier l'article
                </a>
            </div>
        {% endif %}
        
        <header class="text-center mb-16 relative">
            <div class="inline-block px-6 py-2 bg-accent/10 border border-accent/20 rounded-full text-accent font-black uppercase tracking-[0.3em] text-[10px] mb-8 animate-pulse">
                ARTICLE N° {{ article.id }} // CATÉGORIE: {{ article.category ? article.category.name : 'Non classé' }}
            </div>
            <h1 class="font-mystere text-5xl md:text-7xl text-accent leading-tight mb-8 italic tracking-tighter drop-shadow-[0_0_20px_rgba(57,255,20,0.4)]">{{ article.title }}</h1>
            <div class="flex items-center justify-center gap-6 text-[10px] text-mauve-light font-black uppercase tracking-widest">
                <span class="flex items-center gap-2">
                    <span class="opacity-40">AUTEUR:</span>
                    <span class="text-white">{{ article.author.pseudo ?: article.author.email|split('@')[0]|capitalize }}</span>
                </span>
                <span class="w-2 h-2 bg-accent rounded-full shadow-[0_0_10px_#39ff14] animate-ping"></span>
                <time class="flex items-center gap-2">
                    <span class="opacity-40">DATE:</span>
                    <span class="text-white">{{ article.publishedAt|date('d/m/Y') }}</span>
                </time>
            </div>
        </header>

        <div class="mb-16 relative group">
            <div class="absolute -inset-4 bg-accent/5 blur-2xl rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="relative shadow-[0_0_60px_rgba(0,0,0,0.9)] rounded-3xl overflow-hidden bg-black border-2 border-white/5 group-hover:border-accent/30 transition-all duration-500">
                {% if article.videoFile %}
                    <video controls class="w-full h-auto bg-black" poster="{{ article.image ? asset('uploads/articles/' ~ article.image) : '' }}">
                        <source src="{{ asset('videos/' ~ article.videoFile) }}" type="video/mp4">
                        Votre navigateur ne supporte pas la lecture de vidéos.
                    </video>
                {% elseif article.videoUrl %}
                    {% if 'youtube.com' in article.videoUrl or 'youtu.be' in article.videoUrl or 'infomaniak.com' in article.videoUrl %}
                        <div class="relative pb-[56.25%] h-0">
                            <iframe class="absolute top-0 left-0 w-full h-full border-0" src="{{ article.videoUrl }}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                        </div>
                    {% else %}
                        <video controls class="w-full h-auto bg-black" poster="{{ article.image ? asset('uploads/articles/' ~ article.image) : '' }}">
                            <source src="{{ article.videoUrl }}" type="video/mp4">
                            Votre navigateur ne supporte pas la lecture de vidéos.
                        </video>
                    {% endif %}
                {% elseif article.image %}
                    <img src="{{ asset('uploads/articles/' ~ article.image) }}" alt="{{ article.title }}" class="w-full h-auto object-cover max-h-[700px]">
                {% endif %}
                
                {# Scanning Bar #}
                <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                    <div class="absolute top-0 left-0 w-full h-[3px] bg-accent/40 shadow-[0_0_15px_#39ff14] animate-scan-slow"></div>
                </div>
            </div>
        </div>

        <div class="max-w-3xl mx-auto">
            <div class="prose prose-invert prose-lg max-w-none text-gray-300 leading-relaxed font-medium 
                first-letter:text-7xl first-letter:font-mystere first-letter:text-accent first-letter:mr-4 
                first-letter:float-left first-letter:drop-shadow-[0_0_10px_rgba(57,255,20,0.5)] mb-20 
                selection:bg-accent selection:text-primary">
                {{ article.content|raw }}
            </div>

            {% if article.tags|length > 0 %}
                <div class="mt-16 pt-10 border-t border-white/10 flex flex-wrap gap-3">
                    {% for tag in article.tags %}
                        <span class="bg-white/5 text-accent px-5 py-2 rounded-full text-[9px] font-black uppercase tracking-widest border border-white/5 hover:border-accent/50 hover:bg-accent/5 transition-all cursor-crosshair">#{{ tag.name }}</span>
                    {% endfor %}
                </div>
            {% endif %}

            {# Section Commentaires #}
            <section id="comments" class="mt-32 pt-16 border-t-2 border-accent/20">
                <div class="flex items-center gap-6 mb-16">
                    <h3 class="font-mystere text-4xl text-accent italic uppercase tracking-widest">
                        Commentaires ({{ article.comments|filter(c => c.isApproved)|length }})
                    </h3>
                    <div class="flex-1 h-[1px] bg-accent/10"></div>
                </div>
                
                <div class="space-y-10 mb-20">
                    {% for comment in article.comments|filter(c => c.isApproved) %}
                        <div class="bg-white/5 backdrop-blur-sm p-10 rounded-3xl border border-white/10 relative shadow-2xl group hover:border-accent/40 transition-all duration-300">
                            <div class="flex items-center gap-6 mb-6">
                                <div class="w-14 h-14 bg-accent text-primary rounded-2xl flex items-center justify-center font-black text-xl uppercase shadow-[0_0_20px_rgba(57,255,20,0.4)] rotate-3 group-hover:rotate-0 transition-transform">
                                    {{ comment.authorName|slice(0, 1)|upper }}
                                </div>
                                <div>
                                    <span class="block font-black text-base uppercase tracking-wider text-white">{{ comment.authorName }}</span>
                                    <time class="text-[9px] font-black text-mauve-light uppercase tracking-[0.2em] opacity-60">{{ comment.createdAt|date('d/m/Y à H:i') }}</time>
                                </div>
                                <div class="ml-auto text-[8px] font-black text-accent/30 tracking-widest uppercase border border-accent/20 px-3 py-1 rounded">VÉRIFIÉ</div>
                            </div>
                            <div class="text-gray-300 leading-loose italic border-l-4 border-accent/20 pl-6 text-lg">
                                "{{ comment.content|nl2br }}"
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-20 border-2 border-dashed border-white/5 rounded-3xl">
                            <p class="text-mauve-light font-black italic opacity-40 uppercase tracking-[0.4em]">Aucun commentaire pour le moment.</p>
                        </div>
                    {% endfor %}
                </div>

                {# Formulaire #}
                <div class="bg-primary/40 backdrop-blur-xl p-10 md:p-16 rounded-[3rem] border border-white/10 shadow-[0_0_100px_rgba(0,0,0,0.5)]">
                    <div class="mb-12">
                        <h4 class="font-mystere text-3xl text-accent mb-4 italic tracking-widest">Laisser un commentaire</h4>
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-mauve-light opacity-60">Votre commentaire sera publié après validation</p>
                    </div>
                    
                    {% for message in app.flashes('success') %}
                        <div class="bg-accent/10 border border-accent/30 text-accent p-6 mb-12 font-black text-xs uppercase tracking-widest rounded-xl animate-bounce">
                            ✓ Commentaire envoyé. En attente de validation.
                        </div>
                    {% endfor %}

                    {{ form_start(commentForm, {'attr': {'class': 'space-y-10'}}) }}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                            <div class="space-y-4">
                                {{ form_label(commentForm.authorName, null, {'label_attr': {'class': 'block text-[9px] font-black uppercase tracking-[0.3em] text-accent/70'}}) }}
                                {{ form_widget(commentForm.authorName, {'attr': {'class': 'w-full bg-white/5 border border-white/10 focus:border-accent focus:bg-accent/5 rounded-2xl px-6 py-4 transition-all text-white placeholder:text-white/20'}}) }}
                            </div>
                            <div class="space-y-4">
                                {{ form_label(commentForm.authorEmail, null, {'label_attr': {'class': 'block text-[9px] font-black uppercase tracking-[0.3em] text-accent/70'}}) }}
                                {{ form_widget(commentForm.authorEmail, {'attr': {'class': 'w-full bg-white/5 border border-white/10 focus:border-accent focus:bg-accent/5 rounded-2xl px-6 py-4 transition-all text-white placeholder:text-white/20'}}) }}
                            </div>
                        </div>
                        <div class="space-y-4">
                            {{ form_label(commentForm.content, null, {'label_attr': {'class': 'block text-[9px] font-black uppercase tracking-[0.3em] text-accent/70'}}) }}
                            {{ form_widget(commentForm.content, {'attr': {'class': 'w-full bg-white/5 border border-white/10 focus:border-accent focus:bg-accent/5 rounded-[2rem] px-8 py-6 min-h-[200px] transition-all text-white placeholder:text-white/20'}}) }}
                        </div>
                        <div class="pt-6 text-center md:text-left">
                            <button type="submit" class="group relative px-16 py-6 bg-accent text-primary rounded-full font-black uppercase text-xs tracking-[0.3em] overflow-hidden transition-all hover:scale-105 hover:shadow-[0_0_50px_rgba(57,255,20,0.5)]">
                                <span class="relative z-10">Envoyer le commentaire</span>
                                <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                            </button>
                        </div>
                    {{ form_end(commentForm) }}
                </div>
            </section>

            <div class="mt-16 text-center">
                <a href="{{ path('blog_articles') }}" class="inline-flex items-center gap-2 text-mauve-light font-black uppercase text-[10px] tracking-[0.2em] hover:text-accent transition-colors">
                    <span class="text-lg">←</span> Retour aux articles
                </a>
            </div>
        </div>
    </article>
{% endblock %}
