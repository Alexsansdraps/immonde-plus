{% extends 'base.html.twig' %}

{% block title %}Le Labyrinthe des Doubles - Imm🧅nde Plus{% endblock %}

{% block body %}
<div id="game-portal" class="max-w-4xl mx-auto py-12 text-center">
    <div class="mb-12">
        <h1 class="font-mystere text-6xl md:text-8xl text-accent uppercase tracking-widest italic mb-6 glitch-hover">L'Archive des Doubles</h1>
        <p class="text-mauve-light font-black uppercase text-xs md:text-sm tracking-[0.4em] flicker">VÉRIFIEZ VOTRE SANTÉ MENTALE</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 text-left bg-primary/60 p-8 rounded-3xl border border-mauve-dark">
        <div>
            <h3 class="text-accent font-mystere text-2xl mb-4 uppercase">Le Protocole</h3>
            <p class="text-white text-xs leading-relaxed font-bold uppercase tracking-widest opacity-80">
                Mickaël se démultiplie. Retrouvez ses visages identiques pour nettoyer l'archive. 
            </p>
        </div>
        <div>
            <h3 class="text-accent font-mystere text-2xl mb-4 uppercase">Règles de l'Ombre</h3>
            <p class="text-white text-xs leading-relaxed font-bold uppercase tracking-tighter opacity-80">
                <span class="text-red-500">5 ERREURS</span> et votre cerveau est considéré comme corrompu. La partie s'arrête immédiatement.
            </p>
        </div>
    </div>

    <button id="launch-button" class="group relative bg-accent text-primary px-16 py-8 rounded-full font-mystere text-4xl md:text-6xl tracking-widest hover:scale-110 transition-all shadow-[0_0_50px_rgba(57,255,20,0.6)] uppercase animate-pulse">
        <span class="relative z-10">OUVRIR LE DOSSIER</span>
    </button>
</div>

<div id="game-container" class="max-w-5xl mx-auto py-12 hidden">
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div id="status-badge" class="bg-black/60 px-8 py-4 rounded-full border-2 border-accent/30 backdrop-blur-md min-w-[200px]">
            <span id="game-status-text" class="text-accent font-black text-2xl md:text-3xl tracking-tighter uppercase animate-pulse">MÉMORISATION...</span>
        </div>
        <div class="flex items-center gap-4">
            <div id="lives-container" class="bg-black/60 px-8 py-4 rounded-full border-2 border-red-500/30 backdrop-blur-md">
                <span class="text-red-500 font-black text-2xl md:text-4xl tracking-tighter uppercase">Erreurs : <span id="error-count">0</span> / 5</span>
            </div>
            <div class="bg-black/60 px-6 py-4 rounded-full border-2 border-mauve-light/20 backdrop-blur-md hidden md:block">
                <span class="text-mauve-light font-black text-sm tracking-tighter uppercase">Record : <span id="best-record">—</span></span>
            </div>
        </div>
    </div>

    <div id="memory-grid" class="grid grid-cols-4 md:grid-cols-4 gap-4 md:gap-8 perspective-1000 pointer-events-none">
        {# Les cartes seront générées ici par JS #}
    </div>
</div>

{# UI Pour le score caché pendant la preview #}
<div id="score-overlay" class="hidden">
    <span class="text-accent font-black text-2xl md:text-4xl tracking-tighter uppercase">Paires : <span id="pair-count">0</span> / 8</span>
</div>

{# Game Over Modal #}
<div id="game-over" class="fixed inset-0 bg-black/95 flex flex-col items-center justify-center hidden z-[2000] p-8 text-center">
    <h2 id="status-title" class="font-mystere text-7xl md:text-9xl text-red-600 mb-8 uppercase italic">CERVEAU CORROMPU</h2>
    <p id="status-desc" class="text-white text-xl md:text-2xl mb-12 font-black uppercase tracking-[0.2em]">Vous avez échoué à identifier les doubles.</p>
    <div class="flex flex-col gap-6 w-full max-w-sm">
        <button id="restart-btn" class="bg-accent text-primary py-6 rounded-full font-mystere text-4xl uppercase shadow-[0_0_50px_rgba(57,255,20,0.6)]">RÉESSAYER</button>
        <button id="exit-btn" class="bg-mauve-dark text-white py-4 rounded-full font-black uppercase">ABANDONNER</button>
    </div>
</div>

<script>
    const images = [
        'FB_IMG_1547495556903.jpg',
        'FB_IMG_1549336705798.jpg',
        'FB_IMG_1551128546719.jpg',
        'IMG_20190320_195757.jpg',
        'IMG_20190320_195812.jpg',
        'IMG_20190330_211025.jpg',
        'received_334888457205498.png',
        'received_569192993573290.jpeg'
    ];

    const portal = document.getElementById('game-portal');
    const container = document.getElementById('game-container');
    const grid = document.getElementById('memory-grid');
    const pairCountEl = document.getElementById('pair-count');
    const errorCountEl = document.getElementById('error-count');
    const gameOverScreen = document.getElementById('game-over');
    const statusTitle = document.getElementById('status-title');
    const statusDesc = document.getElementById('status-desc');
    
    let cards = [];
    let flippedCards = [];
    let pairsFound = 0;
    let errors = 0;
    let isProcessing = false;

    const statusBadge = document.getElementById('status-badge');
    const statusText = document.getElementById('game-status-text');
    const bestRecordEl = document.getElementById('best-record');

    const fx = window.ImmondeFX;
    // Record = moins d'erreurs sur une partie gagnée (mode 'min')
    function refreshRecord() {
        const best = fx && fx.getHighScore('paires');
        bestRecordEl.innerText = (best === null || best === undefined) ? '—' : best + ' err.';
    }
    refreshRecord();

    function initGame() {
        pairsFound = 0;
        errors = 0;
        flippedCards = [];
        isProcessing = true; // Bloquer les clics pendant la preview
        grid.innerHTML = '';
        grid.classList.add('pointer-events-none');
        pairCountEl.innerText = '0';
        errorCountEl.innerText = '0';
        statusText.innerText = "MÉMORISATION...";
        statusText.className = "text-accent font-black text-2xl md:text-3xl tracking-tighter uppercase animate-pulse";
        
        const gameImages = [...images, ...images];
        gameImages.sort(() => Math.random() - 0.5);

        gameImages.forEach((img, index) => {
            const card = document.createElement('div');
            card.className = 'memory-card relative aspect-square cursor-pointer group';
            card.dataset.image = img;
            card.dataset.index = index;

            card.innerHTML = `
                <div class="card-inner w-full h-full relative transition-transform duration-500 preserve-3d shadow-2xl">
                    <div class="card-front absolute inset-0 bg-mauve-dark/40 border-2 border-mauve-dark rounded-2xl flex items-center justify-center backface-hidden group-hover:border-accent transition-colors">
                        <span class="text-4xl grayscale opacity-30 group-hover:opacity-100 group-hover:grayscale-0 transition-all">🧅</span>
                    </div>
                    <div class="card-back absolute inset-0 bg-primary border-2 border-accent rounded-2xl overflow-hidden backface-hidden rotate-y-180">
                        <img src="/img/jeu-paires/${img}" class="w-full h-full object-cover">
                    </div>
                </div>
            `;

            card.addEventListener('click', () => flipCard(card));
            grid.appendChild(card);
        });

        // --- PHASE DE MÉMORISATION ---
        setTimeout(() => {
            // Retourner toutes les cartes
            document.querySelectorAll('.card-inner').forEach(inner => inner.classList.add('rotate-y-180'));
            
            let countdown = 3;
            statusText.innerText = `IDENTIFIEZ : ${countdown}s`;
            
            const timer = setInterval(() => {
                countdown--;
                if (countdown > 0) {
                    statusText.innerText = `IDENTIFIEZ : ${countdown}s`;
                } else {
                    clearInterval(timer);
                    // Cacher les cartes et lancer le jeu
                    document.querySelectorAll('.card-inner').forEach(inner => inner.classList.remove('rotate-y-180'));
                    statusText.innerText = "À VOUS !";
                    statusText.classList.remove('animate-pulse');
                    grid.classList.remove('pointer-events-none');
                    isProcessing = false;
                }
            }, 1000);
        }, 500);
    }

    function flipCard(card) {
        if (isProcessing || flippedCards.includes(card) || card.classList.contains('found')) return;

        card.querySelector('.card-inner').classList.add('rotate-y-180');
        if (fx) { fx.play('pop'); fx.vibrate(10); }
        flippedCards.push(card);

        if (flippedCards.length === 2) {
            checkMatch();
        }
    }

    function checkMatch() {
        isProcessing = true;
        const [card1, card2] = flippedCards;
        const match = card1.dataset.image === card2.dataset.image;

        if (match) {
            pairsFound++;
            pairCountEl.innerText = pairsFound;
            card1.classList.add('found');
            card2.classList.add('found');
            flippedCards = [];
            isProcessing = false;
            if (fx) { fx.play('success'); fx.vibrate([15, 10, 15]); }

            if (pairsFound === images.length) {
                victory();
            }
        } else {
            errors++;
            errorCountEl.innerText = errors;
            if (fx) { fx.play('error'); fx.vibrate(50); }

            // Animation d'erreur sur le container
            errorCountEl.parentElement.classList.add('shake');
            setTimeout(() => errorCountEl.parentElement.classList.remove('shake'), 500);

            if (errors >= 5) {
                setTimeout(lose, 600);
            } else {
                setTimeout(() => {
                    card1.querySelector('.card-inner').classList.remove('rotate-y-180');
                    card2.querySelector('.card-inner').classList.remove('rotate-y-180');
                    flippedCards = [];
                    isProcessing = false;
                }, 1000);
            }
        }
    }

    function victory() {
        if (fx) fx.play('bonus');
        const isRecord = fx && fx.setHighScore('paires', errors, 'min');
        refreshRecord();
        statusTitle.innerText = "DOSSIER CLASSÉ";
        statusTitle.className = "font-mystere text-7xl md:text-9xl text-accent mb-8 uppercase italic";
        statusDesc.innerText = isRecord
            ? `🏆 Nouveau record : seulement ${errors} erreur(s) ! Lucidité effrayante.`
            : `Vous avez démasqué tous les doubles en ${errors} erreur(s).`;
        gameOverScreen.classList.remove('hidden');
    }

    function lose() {
        if (fx) { fx.play('death'); fx.vibrate([80, 40, 120]); }
        statusTitle.innerText = "CERVEAU CORROMPU";
        statusTitle.className = "font-mystere text-7xl md:text-9xl text-red-600 mb-8 uppercase italic";
        statusDesc.innerText = "Trop d'erreurs d'identification. Mickaël a pris le dessus sur votre vision.";
        gameOverScreen.classList.remove('hidden');
    }

    document.getElementById('launch-button').addEventListener('click', () => {
        if (fx) fx.unlock();
        portal.classList.add('hidden');
        container.classList.remove('hidden');
        initGame();
    });

    document.getElementById('restart-btn').addEventListener('click', () => {
        gameOverScreen.classList.add('hidden');
        initGame();
    });

    document.getElementById('exit-btn').addEventListener('click', () => {
        window.location.href = "{{ path('blog_games') }}";
    });
</script>

<style>
    .perspective-1000 { perspective: 1000px; }
    .preserve-3d { transform-style: preserve-3d; }
    .backface-hidden { backface-visibility: hidden; }
    .rotate-y-180 { transform: rotateY(180deg); }
    
    .shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    @keyframes shake {
        10%, 90% { transform: translate3d(-1px, 0, 0); }
        20%, 80% { transform: translate3d(2px, 0, 0); }
        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
        40%, 60% { transform: translate3d(4px, 0, 0); }
    }
</style>
{% endblock %}
