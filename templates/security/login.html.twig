{% extends 'base.html.twig' %}

{% block title %}Connexion - Imm🧅nde Plus{% endblock %}

{% block body %}
<div class="max-w-md mx-auto py-12">
    <div class="bg-primary/80 p-8 md:p-12 rounded-3xl border-2 border-mauve-dark shadow-2xl">
        <h1 class="font-mystere text-4xl text-accent mb-8 italic tracking-widest text-center uppercase">Accès Rédaction</h1>
        
        <form method="post" class="space-y-6">
            {% if error %}
                <div class="bg-red-500/20 border-l-4 border-red-500 text-red-200 p-4 mb-6 font-bold text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="text-mauve-light text-sm mb-6 text-center italic">
                    Vous êtes connecté en tant que <span class="text-white font-bold">{{ app.user.userIdentifier }}</span>.
                    <br>
                    <a href="{{ path('app_logout') }}" class="text-accent hover:underline uppercase text-[10px] font-black tracking-widest mt-2 block">Déconnexion</a>
                </div>
            {% endif %}

            <div class="space-y-2">
                <label for="inputPseudo" class="block text-[10px] font-black uppercase tracking-widest text-mauve-light">Pseudo d'Infiltré</label>
                <input type="text" value="{{ last_username }}" name="pseudo" id="inputPseudo" 
                    class="w-full bg-mauve-dark/20 border-0 border-b-2 border-mauve-dark focus:border-accent focus:ring-0 px-4 py-3 transition-colors text-white font-bold placeholder-mauve-dark/50" 
                    autocomplete="username" required autofocus placeholder="Votre pseudo...">
            </div>

            <div class="space-y-2">
                <label for="inputPassword" class="block text-[10px] font-black uppercase tracking-widest text-mauve-light">Code Secret</label>
                <input type="password" name="password" id="inputPassword" 
                    class="w-full bg-mauve-dark/20 border-0 border-b-2 border-mauve-dark focus:border-accent focus:ring-0 px-4 py-3 transition-colors text-white font-bold placeholder-mauve-dark/50" 
                    autocomplete="current-password" required placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="pt-6">
                <button type="submit" 
                    class="w-full bg-accent text-primary px-12 py-4 rounded-full font-black uppercase text-xs tracking-widest hover:scale-105 transition-all shadow-[0_0_20px_rgba(57,255,20,0.3)] hover:shadow-accent/40">
                    S'infiltrer dans l'administration
                </button>
            </div>
        </form>

        <div class="mt-12 text-center">
            <a href="{{ path('blog_index') }}" class="inline-flex items-center gap-2 text-mauve-light font-black uppercase text-[10px] tracking-[0.2em] hover:text-accent transition-colors">
                <span class="text-lg">←</span> Retour à la surface
            </a>
        </div>
    </div>
</div>
{% endblock %}
