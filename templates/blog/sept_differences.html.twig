{% extends 'base.html.twig' %}

{% block title %}Les 7 Différences Immondes | Imm🧅nde Plus{% endblock %}

{% block body %}

{# ===== PORTAL (intro screen) ===== #}
<div id="diff-portal" class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="mb-12">
        <h1 class="font-mystere text-5xl md:text-7xl text-accent uppercase tracking-widest italic mb-6 glitch-hover">Les Différences</h1>
        <p class="text-mauve-light font-black uppercase text-xs md:text-sm tracking-[0.4em] flicker">TROUVE LES ANOMALIES DANS LES ÉGOUTS</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mb-12 text-left bg-primary/60 p-8 rounded-3xl border border-mauve-dark">
        <div>
            <h3 class="text-accent font-mystere text-2xl mb-4 uppercase">Comment jouer</h3>
            <ul class="text-white space-y-2 text-sm font-bold uppercase tracking-widest">
                <li><span class="text-accent">CLIQUE</span> sur une différence dans l'image de droite</li>
                <li><span class="text-accent">CERCLE VERT</span> = différence trouvée</li>
                <li><span class="text-accent">CERCLE ROUGE</span> = mauvais endroit</li>
            </ul>
        </div>
        <div>
            <h3 class="text-accent font-mystere text-2xl mb-4 uppercase">Objectif</h3>
            <p class="text-white text-xs leading-relaxed font-bold uppercase tracking-tighter opacity-80">
                Trouve toutes les <span class="text-accent" id="portal-diff-count">?</span> différences entre les deux images avant que ton cerveau ne lâche.
            </p>
        </div>
    </div>

    <button id="start-btn" class="group relative bg-accent text-primary px-16 py-8 rounded-full font-mystere text-3xl md:text-5xl tracking-widest hover:scale-110 transition-all shadow-[0_0_50px_rgba(57,255,20,0.6)] uppercase animate-pulse">
        INSPECTER LES ÉGOUTS
    </button>
</div>

{# ===== GAME CONTAINER ===== #}
<div id="game-container" class="hidden pb-20 px-2 md:px-4">

    {# Header stats #}
    <div class="flex flex-wrap items-center justify-between gap-4 mb-4 bg-primary/60 px-6 py-4 rounded-2xl border border-mauve-dark">
        <div class="flex items-center gap-6">
            <span class="text-accent font-black text-sm uppercase tracking-widest">
                Trouvées : <span id="found-count" class="text-white">0</span> / <span id="total-count">0</span>
            </span>
            <span class="text-mauve-light font-black text-sm uppercase tracking-widest">
                Erreurs : <span id="error-count" class="text-red-400">0</span>
            </span>
        </div>
        <div id="timer-wrapper" class="text-mauve-light font-black text-sm uppercase tracking-widest">
            Temps : <span id="timer" class="text-white">00:00</span>
        </div>
    </div>
    <p id="level-title" class="text-center text-mauve-light font-black uppercase text-[10px] tracking-[0.4em] mb-6"></p>

    {# Differences progress dots #}
    <div id="diff-dots" class="flex flex-wrap gap-3 justify-center mb-8"></div>

    {# Images side by side #}
    <div class="flex flex-col lg:flex-row gap-4 justify-center items-start">

        {# Left image — original (no interaction) #}
        <div class="flex-1 max-w-full lg:max-w-[48%]">
            <p class="text-center text-mauve-light font-black uppercase text-[10px] tracking-[0.4em] mb-3">IMAGE ORIGINALE</p>
            <div class="relative rounded-2xl overflow-hidden border-2 border-mauve-dark">
                <img id="img-left" src="" alt="Image originale" class="w-full block select-none" draggable="false">
                {# Placeholder shown when no image is set #}
                <div id="placeholder-left" class="w-full aspect-video bg-black/60 flex items-center justify-center">
                    <span class="text-mauve-light font-mystere text-2xl uppercase tracking-widest opacity-40">Image à venir</span>
                </div>
            </div>
        </div>

        {# Right image — modified (clickable) #}
        <div class="flex-1 max-w-full lg:max-w-[48%]">
            <p class="text-center text-accent font-black uppercase text-[10px] tracking-[0.4em] mb-3">CLIQUE ICI ↓</p>
            <div class="relative rounded-2xl overflow-hidden border-2 border-accent/40 cursor-crosshair" id="right-wrapper">
                <img id="img-right" src="" alt="Image modifiée" class="w-full block select-none" draggable="false">
                {# Placeholder shown when no image is set #}
                <div id="placeholder-right" class="w-full aspect-video bg-black/60 flex items-center justify-center">
                    <span class="text-mauve-light font-mystere text-2xl uppercase tracking-widest opacity-40">Image à venir</span>
                </div>
                {# SVG overlay for circles #}
                <svg id="circles-svg" class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 100 100" preserveAspectRatio="none"></svg>
            </div>
        </div>
    </div>

    {# Wrong click flash message #}
    <div id="wrong-flash" class="hidden fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 bg-red-900/90 border-2 border-red-500 text-red-300 font-mystere text-3xl uppercase tracking-widest px-10 py-6 rounded-2xl shadow-2xl pointer-events-none">
        RATÉ !
    </div>
</div>

{# ===== LEVEL COMPLETE SCREEN ===== #}
<div id="level-complete-screen" class="hidden max-w-xl mx-auto px-4 pb-20 text-center">
    <div class="mb-8">
        <h2 class="font-mystere text-5xl md:text-6xl text-accent uppercase tracking-widest italic mb-4 glitch-hover">NIVEAU TERMINÉ !</h2>
        <p class="text-mauve-light font-black uppercase text-xs tracking-[0.4em] flicker">TOUTES LES ANOMALIES TROUVÉES</p>
    </div>
    <div class="bg-primary/60 rounded-3xl border-2 border-accent p-8 shadow-[0_0_40px_rgba(57,255,20,0.2)] mb-8">
        <p class="text-white font-black uppercase text-sm tracking-widest">
            Prêt pour le <span class="text-accent">Niveau <span id="next-level-num">2</span></span> ?
        </p>
    </div>
    <button id="next-level-btn" class="bg-accent text-primary px-12 py-5 rounded-full font-mystere text-2xl tracking-widest uppercase hover:scale-105 transition-all shadow-[0_0_20px_rgba(57,255,20,0.4)]">
        NIVEAU SUIVANT →
    </button>
</div>

{# ===== WIN SCREEN ===== #}
<div id="win-screen" class="hidden max-w-xl mx-auto px-4 pb-20 text-center">
    <div class="mb-8">
        <h2 class="font-mystere text-5xl md:text-7xl text-accent uppercase tracking-widest italic mb-4 glitch-hover">BRAVO !</h2>
        <p class="text-mauve-light font-black uppercase text-xs tracking-[0.4em] flicker">TOUTES LES ANOMALIES DÉTECTÉES</p>
    </div>
    <div class="bg-primary/60 rounded-3xl border-2 border-accent p-8 shadow-[0_0_40px_rgba(57,255,20,0.2)] mb-8">
        <p class="text-white font-black uppercase text-sm tracking-widest mb-2">Temps final : <span id="win-time" class="text-accent"></span></p>
        <p class="text-white font-black uppercase text-sm tracking-widest">Erreurs : <span id="win-errors" class="text-red-400"></span></p>
    </div>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button id="retry-btn" class="bg-accent text-primary px-10 py-4 rounded-full font-mystere text-xl tracking-widest uppercase hover:scale-105 transition-all shadow-[0_0_20px_rgba(57,255,20,0.4)]">
            REJOUER
        </button>
        <a href="{{ path('blog_games') }}" class="bg-transparent border-2 border-mauve-dark text-mauve-light px-10 py-4 rounded-full font-mystere text-xl tracking-widest uppercase hover:border-accent hover:text-accent transition-all">
            AUTRES JEUX
        </a>
    </div>
</div>

<script>
// ============================================================
//  CONFIGURATION — niveaux
// ============================================================
const LEVELS = [
    {
        title: "Niveau 1 — La Chambre",
        imageLeft:  '/img/differences/original_01.jpg',
        imageRight: '/img/differences/modified_01.png',
        differences: [
            { x: 42.0, y: 87.0, radius: 4, label: "Pièce de monnaie sur le sol" },
            { x: 68.0, y: 10.0, radius: 3, label: "Point noir sur le mur" },
            { x: 62.0, y: 50.0, radius: 4, label: "Tache brunâtre sur le drap" },
            { x: 88.0, y: 93.0, radius: 4, label: "Petit papier froissé" },
            { x: 20.0, y: 87.0, radius: 4, label: "Petit caillou gris" },
            { x: 20.0, y: 72.0, radius: 4, label: "Débris sous le lit" },
        ]
    },
    {
        title: "Niveau 2 — Les Toilettes",
        imageLeft:  '/img/differences/original_02.jpg',
        imageRight: '/img/differences/modified_02.png',
        differences: [
            { x: 59.0, y: 85.0, radius: 4, label: "Tache sombre sur le sol" },
            { x: 66.0, y: 70.0, radius: 4, label: "Pièce de monnaie sur le sol" },
            { x: 85.0, y: 84.0, radius: 4, label: "Petit morceau de papier blanc" },
        ]
    },
    {
        title: "Niveau 3 — La Salle de Bain",
        imageLeft:  '/img/differences/original_03.jpg',
        imageRight: '/img/differences/modified_03.png',
        differences: [
            { x: 13.0,  y: 7.0, radius: 4, label: "Araignée dans l'angle supérieur gauche" },
            { x: 77.0, y: 70.0, radius: 4, label: "Pièce de monnaie près du lavabo" },
            { x: 55.0, y: 92.0, radius: 4, label: "Élastique noir sur le sol" },
        ]
    },
    {
        title: "Niveau 4 — L'Étagère",
        imageLeft:  '/img/differences/original_04.jpg',
        imageRight: '/img/differences/modified_04.png',
        differences: [
            { x: 34.0, y: 10.0, radius: 4, label: "Araignée sur le mur près de la fenêtre" },
            { x: 66.0, y: 55.0, radius: 4, label: "Tache brunâtre sur l'étagère" },
            { x: 68.0, y: 96.0, radius: 4, label: "Tache brunâtre sur le carrelage" },
        ]
    },
];
// ============================================================

let currentLevel  = 0;
let foundDiffs    = [];
let errorCount    = 0;
let totalErrors   = 0;
let timerInterval = null;
let secondsElapsed = 0;
let gameStarted   = false;

const portalEl      = document.getElementById('diff-portal');
const gameEl        = document.getElementById('game-container');
const winEl         = document.getElementById('win-screen');
const rightWrapper  = document.getElementById('right-wrapper');
const circlesSvg    = document.getElementById('circles-svg');
const foundCountEl  = document.getElementById('found-count');
const totalCountEl  = document.getElementById('total-count');
const errorCountEl  = document.getElementById('error-count');
const timerEl       = document.getElementById('timer');
const diffDotsEl    = document.getElementById('diff-dots');
const wrongFlash    = document.getElementById('wrong-flash');
const imgLeft       = document.getElementById('img-left');
const imgRight      = document.getElementById('img-right');
const phLeft        = document.getElementById('placeholder-left');
const phRight       = document.getElementById('placeholder-right');
const levelTitleEl  = document.getElementById('level-title');

// Set portal total diff count
const totalDiffs = LEVELS.reduce((sum, l) => sum + l.differences.length, 0);
document.getElementById('portal-diff-count').textContent = totalDiffs;

document.getElementById('start-btn').addEventListener('click', startGame);
document.getElementById('retry-btn').addEventListener('click', resetGame);
document.getElementById('next-level-btn').addEventListener('click', goNextLevel);

function startGame() {
    portalEl.classList.add('hidden');
    gameEl.classList.remove('hidden');
    currentLevel = 0;
    totalErrors  = 0;
    secondsElapsed = 0;
    initLevel();
}

function initLevel() {
    const level = LEVELS[currentLevel];
    foundDiffs  = [];
    errorCount  = 0;
    gameStarted = true;

    if (levelTitleEl) levelTitleEl.textContent = level.title;
    foundCountEl.textContent = '0';
    totalCountEl.textContent = level.differences.length;
    errorCountEl.textContent = '0';
    timerEl.textContent      = '00:00';
    circlesSvg.innerHTML     = '';
    diffDotsEl.innerHTML     = '';

    // Load images
    loadImage(imgLeft,  phLeft,  level.imageLeft);
    loadImage(imgRight, phRight, level.imageRight);

    // Build progress dots
    level.differences.forEach((diff, i) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'relative group/dot flex flex-col items-center';

        const dot = document.createElement('div');
        dot.id = `dot-${i}`;
        dot.className = 'w-6 h-6 rounded-full border-2 border-mauve-dark bg-black/40 transition-all duration-300 cursor-default';
        dot.title = diff.label || `Différence ${i + 1}`;

        const tooltip = document.createElement('span');
        tooltip.id = `dot-label-${i}`;
        tooltip.className = 'hidden absolute bottom-8 left-1/2 -translate-x-1/2 bg-black/90 border border-mauve-dark text-mauve-light text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-lg whitespace-nowrap pointer-events-none z-50 opacity-0 transition-opacity duration-200';
        tooltip.textContent = diff.label || `Différence ${i + 1}`;

        wrapper.appendChild(dot);
        wrapper.appendChild(tooltip);
        diffDotsEl.appendChild(wrapper);
    });

    // Timer (continues across levels)
    if (currentLevel === 0) {
        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            secondsElapsed++;
            const m = String(Math.floor(secondsElapsed / 60)).padStart(2, '0');
            const s = String(secondsElapsed % 60).padStart(2, '0');
            timerEl.textContent = `${m}:${s}`;
        }, 1000);
    }

    rightWrapper.addEventListener('click', onRightClick);
}

function loadImage(imgEl, placeholderEl, src) {
    if (!src) return;
    const testImg = new Image();
    testImg.onload = () => {
        imgEl.src = src;
        imgEl.classList.remove('hidden');
        placeholderEl.classList.add('hidden');
    };
    testImg.onerror = () => {
        imgEl.classList.add('hidden');
        placeholderEl.classList.remove('hidden');
    };
    testImg.src = src;
}

function onRightClick(e) {
    if (!gameStarted) return;
    const level = LEVELS[currentLevel];
    const rect  = rightWrapper.getBoundingClientRect();
    const xPct  = ((e.clientX - rect.left) / rect.width)  * 100;
    const yPct  = ((e.clientY - rect.top)  / rect.height) * 100;

    let hit = false;
    level.differences.forEach((diff, i) => {
        if (foundDiffs.includes(i)) return;
        const dist = Math.sqrt(Math.pow(xPct - diff.x, 2) + Math.pow(yPct - diff.y, 2));
        if (dist <= diff.radius) {
            hit = true;
            markFound(i, diff.x, diff.y, diff.radius, diff.label);
        }
    });

    if (!hit) {
        errorCount++;
        totalErrors++;
        errorCountEl.textContent = errorCount;
        showWrongFlash(xPct, yPct);
    }
}

function markFound(index, x, y, radius, label) {
    foundDiffs.push(index);
    foundCountEl.textContent = foundDiffs.length;

    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', x);
    circle.setAttribute('cy', y);
    circle.setAttribute('r', radius);
    circle.setAttribute('fill', 'rgba(57,255,20,0.15)');
    circle.setAttribute('stroke', '#39ff14');
    circle.setAttribute('stroke-width', '0.8');
    circle.style.filter = 'drop-shadow(0 0 4px #39ff14)';
    circlesSvg.appendChild(circle);
    circle.style.opacity = '0';
    circle.style.transition = 'opacity 0.3s ease';
    requestAnimationFrame(() => { circle.style.opacity = '1'; });

    const dot = document.getElementById(`dot-${index}`);
    if (dot) dot.className = 'w-6 h-6 rounded-full border-2 border-accent bg-accent shadow-[0_0_8px_rgba(57,255,20,0.8)] transition-all duration-300 cursor-default';

    const tooltip = document.getElementById(`dot-label-${index}`);
    if (tooltip) {
        tooltip.classList.remove('hidden');
        tooltip.classList.add('opacity-100');
        setTimeout(() => tooltip.classList.remove('opacity-100'), 2000);
    }

    showFoundToast(label || `Différence ${index + 1}`);

    const level = LEVELS[currentLevel];
    if (foundDiffs.length === level.differences.length) {
        gameStarted = false;
        rightWrapper.removeEventListener('click', onRightClick);
        const isLast = currentLevel >= LEVELS.length - 1;
        setTimeout(() => isLast ? showWin() : showLevelComplete(), 600);
    }
}

function showFoundToast(label) {
    let toast = document.getElementById('found-toast');
    if (!toast) {
        toast = document.createElement('div');
        toast.id = 'found-toast';
        toast.className = 'fixed top-24 left-1/2 -translate-x-1/2 z-50 bg-accent/90 text-primary font-black uppercase text-xs tracking-widest px-8 py-3 rounded-full shadow-[0_0_20px_rgba(57,255,20,0.6)] pointer-events-none transition-all duration-300';
        document.body.appendChild(toast);
    }
    toast.textContent = '✓ ' + label;
    toast.style.opacity = '1';
    toast.style.transform = 'translateX(-50%) translateY(0)';
    clearTimeout(toast._hideTimer);
    toast._hideTimer = setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(-50%) translateY(-10px)';
    }, 1500);
}

function showWrongFlash(xPct, yPct) {
    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', xPct);
    circle.setAttribute('cy', yPct);
    circle.setAttribute('r', 4);
    circle.setAttribute('fill', 'rgba(220,38,38,0.2)');
    circle.setAttribute('stroke', '#dc2626');
    circle.setAttribute('stroke-width', '0.8');
    circlesSvg.appendChild(circle);
    setTimeout(() => circle.remove(), 800);
    wrongFlash.classList.remove('hidden');
    setTimeout(() => wrongFlash.classList.add('hidden'), 700);
}

function showLevelComplete() {
    const lvlScreen = document.getElementById('level-complete-screen');
    const nextNum   = document.getElementById('next-level-num');
    if (nextNum) nextNum.textContent = currentLevel + 2;
    gameEl.classList.add('hidden');
    lvlScreen.classList.remove('hidden');
    lvlScreen.style.opacity = '0';
    lvlScreen.style.transform = 'translateY(30px)';
    lvlScreen.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    requestAnimationFrame(() => {
        lvlScreen.style.opacity = '1';
        lvlScreen.style.transform = 'translateY(0)';
    });
}

function goNextLevel() {
    const lvlScreen = document.getElementById('level-complete-screen');
    lvlScreen.classList.add('hidden');
    currentLevel++;
    gameEl.classList.remove('hidden');
    initLevel();
}

function showWin() {
    clearInterval(timerInterval);
    document.getElementById('win-time').textContent   = timerEl.textContent;
    document.getElementById('win-errors').textContent = totalErrors;
    gameEl.classList.add('hidden');
    winEl.classList.remove('hidden');
    winEl.style.opacity = '0';
    winEl.style.transform = 'translateY(30px)';
    winEl.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    requestAnimationFrame(() => {
        winEl.style.opacity = '1';
        winEl.style.transform = 'translateY(0)';
    });
}

function resetGame() {
    clearInterval(timerInterval);
    rightWrapper.removeEventListener('click', onRightClick);
    winEl.classList.add('hidden');
    document.getElementById('level-complete-screen').classList.add('hidden');
    gameEl.classList.remove('hidden');
    currentLevel   = 0;
    totalErrors    = 0;
    secondsElapsed = 0;
    initLevel();
}
</script>
{% endblock %}
