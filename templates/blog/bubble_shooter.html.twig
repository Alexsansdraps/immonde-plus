{% extends 'base.html.twig' %}

{% block title %}Justice Shooter - Le Grand Nettoyage | Imm🧅nde Plus{% endblock %}

{% block body %}
<div id="game-portal" class="max-w-4xl mx-auto py-12 text-center">
    <div class="mb-12">
        <h1 class="font-mystere text-6xl md:text-8xl text-accent uppercase tracking-widest italic mb-6 glitch-hover">Justice Shooter</h1>
        <p class="text-mauve-light font-black uppercase text-xs md:text-sm tracking-[0.4em] flicker">NETTOYEZ LES ÉGOUTS PAR LE VIDE</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 text-left bg-primary/60 p-8 rounded-3xl border border-mauve-dark">
        <div>
            <h3 class="text-accent font-mystere text-2xl mb-4 uppercase">Le Protocole</h3>
            <p class="text-white text-xs leading-relaxed font-bold uppercase tracking-widest opacity-80">
                Alignez 3 éléments identiques pour les pulvériser. Libérez l'espace saturé par l'influence de Mickaël.
            </p>
        </div>
        <div>
            <h3 class="text-accent font-mystere text-2xl mb-4 uppercase">Arsenal</h3>
            <p class="text-white text-xs leading-relaxed font-bold uppercase tracking-tighter opacity-80">
                Visez avec précision. Si les preuves atteignent la <span class="text-red-500">LIGNE ROUGE</span>, le dossier est classé sans suite (Game Over).
            </p>
        </div>
    </div>

    <button id="launch-button" class="group relative bg-accent text-primary px-16 py-8 rounded-full font-mystere text-4xl md:text-6xl tracking-widest hover:scale-110 transition-all shadow-[0_0_50px_rgba(57,255,20,0.6)] uppercase animate-pulse">
        <span class="relative z-10">DÉGOMMER</span>
    </button>
</div>

<div id="game-container" class="fixed inset-0 bg-black z-[1000] hidden flex flex-col items-center justify-center overflow-hidden">
    <canvas id="bubble-canvas" class="bg-[#050505] shadow-[0_0_50px_rgba(57,255,20,0.2)]"></canvas>
    
    {# UI Stats #}
    <div class="absolute top-8 left-8 flex flex-col gap-2 pointer-events-none z-[1200]">
        <div class="bg-black/60 px-6 py-2 rounded-full border border-accent/30 backdrop-blur-md">
            <span class="text-accent font-black text-xl md:text-3xl tracking-tighter uppercase">NIVEAU : <span id="level-display">1</span></span>
        </div>
        <div class="bg-black/60 px-6 py-2 rounded-full border border-mauve-light/30 backdrop-blur-md">
            <span class="text-mauve-light font-black text-xl md:text-3xl tracking-tighter uppercase">SCORE : <span id="score-display">0</span></span>
        </div>
        <div class="bg-black/60 px-6 py-2 rounded-full border border-yellow-500/30 backdrop-blur-md">
            <span class="text-yellow-400 font-black text-sm md:text-xl tracking-tighter uppercase">RECORD : <span id="best-display">0</span></span>
        </div>
    </div>

    {# Prochaine Bulle #}
    <div class="absolute bottom-8 left-8 z-[1200] bg-black/60 p-4 rounded-3xl border border-accent/20 backdrop-blur-sm flex flex-col items-center">
        <span class="text-[8px] font-black text-accent uppercase mb-2">PROCHAIN</span>
        <div id="next-bubble-preview" class="text-4xl"></div>
    </div>

    {# Game Over / Win Modal #}
    <div id="game-modal" class="absolute inset-0 bg-black/95 flex flex-col items-center justify-center hidden z-[1300] p-8 text-center">
        <h2 id="modal-title" class="font-mystere text-7xl md:text-9xl text-red-600 mb-8 uppercase italic">SATURE !</h2>
        <p id="modal-desc" class="text-white text-2xl md:text-4xl mb-12 font-black uppercase">DOSSIER CORROMPU</p>
        <div class="flex flex-col gap-6 w-full max-w-sm">
            <button id="modal-btn" class="bg-accent text-primary py-6 rounded-full font-mystere text-4xl uppercase shadow-[0_0_50px_rgba(57,255,20,0.6)]">RÉCIDIVER</button>
            <button id="exit-btn" class="bg-mauve-dark text-white py-4 rounded-full font-black uppercase">QUITTER</button>
        </div>
    </div>
</div>

<script>
    const canvas = document.getElementById('bubble-canvas');
    const ctx = canvas.getContext('2d');
    const container = document.getElementById('game-container');
    const portal = document.getElementById('game-portal');
    const launchBtn = document.getElementById('launch-button');
    const scoreDisplay = document.getElementById('score-display');
    const bestDisplay = document.getElementById('best-display');
    const levelDisplay = document.getElementById('level-display');
    const nextPreview = document.getElementById('next-bubble-preview');
    const modal = document.getElementById('game-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalDesc = document.getElementById('modal-desc');
    const modalBtn = document.getElementById('modal-btn');
    const exitBtn = document.getElementById('exit-btn');

    const fx = window.ImmondeFX;

    const icons = ['🤢', '👮', '🧀', '🍺', '🔫', '🚓', '⚖️'];

    // Géométrie hexagonale : lignes paires alignées, lignes impaires décalées d'un demi.
    const COLS = 9;
    const TOP_ROWS = 5;        // rangées remplies au départ (augmente avec le niveau)
    const DEATH_ROW_MARGIN = 120; // distance avant la ligne rouge = game over
    let R = 22;                // rayon d'une bulle (recalculé au resize)
    let rowH = R * 1.7;        // hauteur entre deux rangées
    let originY = 50;

    let grid = [];             // grid[r][c] = type (int) ou null
    let score = 0, level = 1;
    let isRunning = false;
    let currentBubble = null, nextType = 0;
    let shot = null;           // projectile en vol
    let pops = [];             // particules d'éclatement
    let aimAngle = -Math.PI / 2;
    let animationId;

    function colsForRow(r) { return (r % 2 === 0) ? COLS : COLS - 1; }
    function cellX(r, c) {
        const offset = (r % 2 === 0) ? R : 2 * R;
        return offset + c * 2 * R;
    }
    function cellY(r) { return originY + r * rowH; }
    function gridWidth() { return COLS * 2 * R; }

    function resize() {
        const h = window.innerHeight;
        const w = Math.min(window.innerWidth, h * 0.62);
        canvas.width = w;
        canvas.height = h;
        R = Math.floor(w / (COLS * 2 + 1));
        rowH = R * 1.7;
    }

    function maxRows() { return Math.floor((canvas.height - DEATH_ROW_MARGIN - originY) / rowH); }

    function initLevel(resetScore = true) {
        resize();
        grid = [];
        const filled = Math.min(TOP_ROWS + (level - 1), maxRows() - 2);
        const totalRows = maxRows();
        for (let r = 0; r < totalRows; r++) {
            grid[r] = [];
            const cc = colsForRow(r);
            for (let c = 0; c < cc; c++) {
                grid[r][c] = r < filled ? icons.length === 0 ? 0 : Math.floor(Math.random() * Math.min(icons.length, 4 + level)) : null;
            }
        }
        if (resetScore) score = 0;
        nextType = randomActiveType();
        loadNextBubble();
        refreshRecord();
        updateUI();
    }

    // Ne tire que des types encore présents dans la grille (évite les bulles inutiles)
    function randomActiveType() {
        const present = new Set();
        grid.forEach(row => row && row.forEach(v => { if (v !== null) present.add(v); }));
        const pool = present.size ? [...present] : icons.map((_, i) => i);
        return pool[Math.floor(Math.random() * pool.length)];
    }

    function loadNextBubble() {
        const t = nextType;
        nextType = randomActiveType();
        nextPreview.innerText = icons[nextType];
        currentBubble = { x: canvas.width / 2, y: canvas.height - R - 20, type: t };
    }

    function updateUI() {
        scoreDisplay.innerText = score;
        levelDisplay.innerText = level;
    }
    function refreshRecord() {
        const best = fx && fx.getHighScore('bubble');
        bestDisplay.innerText = (best === null || best === undefined) ? 0 : best;
    }

    function shoot(clientX, clientY) {
        if (!isRunning || shot || !currentBubble) return;
        const rect = canvas.getBoundingClientRect();
        const mx = clientX - rect.left, my = clientY - rect.top;
        let ang = Math.atan2(my - currentBubble.y, mx - currentBubble.x);
        // On interdit de tirer vers le bas
        if (ang > -0.15) ang = -0.15;
        if (ang < -Math.PI + 0.15) ang = -Math.PI + 0.15;
        const SPEED = Math.max(10, R * 0.5);
        shot = { x: currentBubble.x, y: currentBubble.y, vx: Math.cos(ang) * SPEED, vy: Math.sin(ang) * SPEED, type: currentBubble.type };
        currentBubble = null;
        if (fx) fx.play('shoot');
    }

    function nearestEmptyCell(x, y) {
        let best = null, bestD = Infinity;
        for (let r = 0; r < grid.length; r++) {
            for (let c = 0; c < colsForRow(r); c++) {
                if (grid[r][c] !== null) continue;
                const d = Math.hypot(x - cellX(r, c), y - cellY(r));
                if (d < bestD) { bestD = d; best = { r, c }; }
            }
        }
        return best;
    }

    function collides(x, y) {
        for (let r = 0; r < grid.length; r++) {
            for (let c = 0; c < colsForRow(r); c++) {
                if (grid[r][c] === null) continue;
                if (Math.hypot(x - cellX(r, c), y - cellY(r)) < R * 1.8) return true;
            }
        }
        return false;
    }

    function neighbors(r, c) {
        const even = r % 2 === 0;
        const cand = even
            ? [[r, c-1],[r, c+1],[r-1, c-1],[r-1, c],[r+1, c-1],[r+1, c]]
            : [[r, c-1],[r, c+1],[r-1, c],[r-1, c+1],[r+1, c],[r+1, c+1]];
        return cand.filter(([nr, nc]) => nr >= 0 && nr < grid.length && nc >= 0 && nc < colsForRow(nr));
    }

    function sameColorCluster(r, c) {
        const type = grid[r][c];
        const seen = new Set([r + ',' + c]);
        const stack = [[r, c]], out = [[r, c]];
        while (stack.length) {
            const [cr, cc] = stack.pop();
            for (const [nr, nc] of neighbors(cr, cc)) {
                const k = nr + ',' + nc;
                if (!seen.has(k) && grid[nr][nc] === type) {
                    seen.add(k); stack.push([nr, nc]); out.push([nr, nc]);
                }
            }
        }
        return out;
    }

    // Toutes les bulles reliées au plafond (rangée 0) survivent ; les autres tombent.
    function dropFloating() {
        const attached = new Set();
        const stack = [];
        for (let c = 0; c < colsForRow(0); c++) if (grid[0][c] !== null) { stack.push([0, c]); attached.add('0,' + c); }
        while (stack.length) {
            const [r, c] = stack.pop();
            for (const [nr, nc] of neighbors(r, c)) {
                const k = nr + ',' + nc;
                if (grid[nr][nc] !== null && !attached.has(k)) { attached.add(k); stack.push([nr, nc]); }
            }
        }
        let dropped = 0;
        for (let r = 0; r < grid.length; r++) {
            for (let c = 0; c < colsForRow(r); c++) {
                if (grid[r][c] !== null && !attached.has(r + ',' + c)) {
                    spawnPop(cellX(r, c), cellY(r), grid[r][c]);
                    grid[r][c] = null; dropped++;
                }
            }
        }
        return dropped;
    }

    function placeShot() {
        const cell = nearestEmptyCell(shot.x, shot.y);
        if (!cell) { shot = null; loadNextBubble(); return; }
        grid[cell.r][cell.c] = shot.type;
        const type = shot.type;
        shot = null;

        const cluster = sameColorCluster(cell.r, cell.c);
        if (cluster.length >= 3) {
            cluster.forEach(([r, c]) => { spawnPop(cellX(r, c), cellY(r), grid[r][c]); grid[r][c] = null; });
            const dropped = dropFloating();
            score += cluster.length * 10 + dropped * 20;
            if (fx) { fx.play('pop'); fx.vibrate(dropped > 0 ? [20, 15, 25] : 15); }
        } else {
            if (fx) fx.play('hit');
        }
        updateUI();

        if (gridEmpty()) { level++; nextLevel(); return; }
        if (gridReachedBottom()) return endGame(false);
        loadNextBubble();
    }

    function gridEmpty() {
        return grid.every(row => row.every(v => v === null));
    }
    function gridReachedBottom() {
        const limit = canvas.height - DEATH_ROW_MARGIN;
        for (let r = 0; r < grid.length; r++)
            for (let c = 0; c < colsForRow(r); c++)
                if (grid[r][c] !== null && cellY(r) + R >= limit) return true;
        return false;
    }

    function nextLevel() {
        if (fx) fx.play('success');
        modalTitle.innerText = "SECTEUR PURGÉ";
        modalTitle.style.color = "#39ff14";
        modalDesc.innerText = `Niveau ${level - 1} nettoyé. Score : ${score}`;
        modalBtn.innerText = "NIVEAU SUIVANT";
        isRunning = false;
        cancelAnimationFrame(animationId);
        modal.classList.remove('hidden');
    }

    function spawnPop(x, y, type) {
        for (let i = 0; i < 6; i++) {
            const a = Math.random() * Math.PI * 2, s = Math.random() * 4 + 1;
            pops.push({ x, y, vx: Math.cos(a) * s, vy: Math.sin(a) * s, life: 1, icon: icons[type] });
        }
    }

    function loop() {
        if (!isRunning) return;

        // Projectile
        if (shot) {
            shot.x += shot.vx; shot.y += shot.vy;
            if (shot.x < R) { shot.x = R; shot.vx *= -1; }
            if (shot.x > canvas.width - R) { shot.x = canvas.width - R; shot.vx *= -1; }
            if (shot.y <= originY || collides(shot.x, shot.y)) placeShot();
        }

        draw();
        animationId = requestAnimationFrame(loop);
    }

    function drawBubbleAt(x, y, type, scale = 1) {
        ctx.font = `${R * 1.7 * scale}px serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.shadowBlur = 12; ctx.shadowColor = 'rgba(57, 255, 20, 0.25)';
        ctx.fillText(icons[type], x, y);
        ctx.shadowBlur = 0;
    }

    function draw() {
        ctx.fillStyle = '#050505';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Ligne rouge de saturation
        const limitY = canvas.height - DEATH_ROW_MARGIN;
        ctx.strokeStyle = '#ef4444'; ctx.lineWidth = 2; ctx.setLineDash([8, 6]);
        ctx.beginPath(); ctx.moveTo(0, limitY); ctx.lineTo(canvas.width, limitY); ctx.stroke();
        ctx.setLineDash([]);

        // Grille
        for (let r = 0; r < grid.length; r++)
            for (let c = 0; c < colsForRow(r); c++)
                if (grid[r][c] !== null) drawBubbleAt(cellX(r, c), cellY(r), grid[r][c]);

        // Ligne de visée
        if (currentBubble) {
            ctx.strokeStyle = 'rgba(57,255,20,0.35)'; ctx.lineWidth = 2; ctx.setLineDash([4, 8]);
            ctx.beginPath();
            ctx.moveTo(currentBubble.x, currentBubble.y);
            ctx.lineTo(currentBubble.x + Math.cos(aimAngle) * 220, currentBubble.y + Math.sin(aimAngle) * 220);
            ctx.stroke(); ctx.setLineDash([]);
            drawBubbleAt(currentBubble.x, currentBubble.y, currentBubble.type);
        }

        // Projectile
        if (shot) drawBubbleAt(shot.x, shot.y, shot.type);

        // Particules
        for (let i = pops.length - 1; i >= 0; i--) {
            const p = pops[i];
            p.x += p.vx; p.y += p.vy; p.vy += 0.2; p.life -= 0.05;
            if (p.life <= 0) { pops.splice(i, 1); continue; }
            ctx.globalAlpha = Math.max(0, p.life);
            ctx.font = `${R}px serif`;
            ctx.fillText(p.icon, p.x, p.y);
            ctx.globalAlpha = 1;
        }
    }

    function startGame() {
        if (fx) fx.unlock();
        resize();
        portal.classList.add('hidden');
        container.classList.remove('hidden');
        modal.classList.add('hidden');
        level = 1;
        isRunning = true;
        pops = []; shot = null;
        initLevel(true);
        cancelAnimationFrame(animationId);
        animationId = requestAnimationFrame(loop);
    }

    function continueGame() {
        modal.classList.add('hidden');
        modalBtn.innerText = "RÉCIDIVER";
        isRunning = true;
        pops = []; shot = null;
        initLevel(false); // garde le score
        cancelAnimationFrame(animationId);
        animationId = requestAnimationFrame(loop);
    }

    function endGame(win) {
        isRunning = false;
        cancelAnimationFrame(animationId);
        if (fx) fx.play('death');
        const isRecord = fx && fx.setHighScore('bubble', score, 'max');
        refreshRecord();
        modal.classList.remove('hidden');
        modalBtn.innerText = "RÉCIDIVER";
        modalTitle.innerText = win ? "PURGE RÉUSSIE" : "DOSSIER SATURÉ";
        modalTitle.style.color = win ? "#39ff14" : "#ef4444";
        modalDesc.innerText = (isRecord && score > 0)
            ? `🏆 Record : ${score} ! Mickaël recule.`
            : (win ? "Secteur nettoyé." : `Mickaël a gagné du terrain. Score : ${score}`);
    }

    // Le bouton du modal : soit on passe au niveau suivant, soit on rejoue
    function onModalBtn() {
        if (modalBtn.innerText === "NIVEAU SUIVANT") continueGame();
        else startGame();
    }

    // --- Entrées ---
    function pointerAim(clientX, clientY) {
        if (!currentBubble) return;
        const rect = canvas.getBoundingClientRect();
        let ang = Math.atan2(clientY - rect.top - currentBubble.y, clientX - rect.left - currentBubble.x);
        if (ang > -0.15) ang = -0.15;
        if (ang < -Math.PI + 0.15) ang = -Math.PI + 0.15;
        aimAngle = ang;
    }

    launchBtn.addEventListener('click', startGame);
    canvas.addEventListener('mousemove', (e) => pointerAim(e.clientX, e.clientY));
    canvas.addEventListener('mousedown', (e) => { pointerAim(e.clientX, e.clientY); shoot(e.clientX, e.clientY); });
    canvas.addEventListener('touchmove', (e) => { e.preventDefault(); const t = e.touches[0]; pointerAim(t.clientX, t.clientY); }, { passive: false });
    canvas.addEventListener('touchstart', (e) => { e.preventDefault(); const t = e.touches[0]; pointerAim(t.clientX, t.clientY); shoot(t.clientX, t.clientY); }, { passive: false });
    exitBtn.addEventListener('click', () => window.location.href = "{{ path('blog_games') }}");
    modalBtn.addEventListener('click', onModalBtn);

    window.addEventListener('resize', () => { if (isRunning) resize(); });
</script>

<style>
    #bubble-canvas {
        border: 4px solid #39ff14;
        border-radius: 2rem;
        max-height: 90vh;
    }
</style>
{% endblock %}
