        {{ importmap('app') }}
        <script>
            // Tesla Core Logic
            (function() {
                if (window.soundLogicInitialized) return;

                window.handleTeslaBurger = () => {
                    const burgerBtn = document.getElementById('burger-menu-btn');
                    const overlay = document.getElementById('mobile-menu-overlay');
                    const icon = document.getElementById('burger-icon');
                    const mobileLinks = document.querySelectorAll('.mobile-link');

                    if (!burgerBtn || !overlay || burgerBtn.hasAttribute('data-listener-added')) return;

                    const toggleMenu = () => {
                        const isOpen = overlay.classList.contains('translate-x-0');
                        if (isOpen) {
                            overlay.classList.remove('translate-x-0');
                            overlay.classList.add('translate-x-full');
                            icon.textContent = '☰';
                            document.body.style.overflow = '';
                        } else {
                            overlay.classList.remove('translate-x-full');
                            overlay.classList.add('translate-x-0');
                            icon.textContent = '✕';
                            document.body.style.overflow = 'hidden';
                        }
                    };

                    burgerBtn.addEventListener('click', toggleMenu);
                    mobileLinks.forEach(link => {
                        link.addEventListener('click', () => {
                            overlay.classList.remove('translate-x-0');
                            overlay.classList.add('translate-x-full');
                            icon.textContent = '☰';
                            document.body.style.overflow = '';
                        });
                    });
                    burgerBtn.setAttribute('data-listener-added', 'true');
                };

                const runAllTeslaLogic = () => {
                    window.handleTeslaBurger();
                    window.initTeslaSlime();
                };

                // Initial run
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', runAllTeslaLogic);
                } else {
                    runAllTeslaLogic();
                }

                // Turbo run
                document.addEventListener('turbo:load', runAllTeslaLogic);

                window.soundLogicInitialized = true;
            })();

            // Logic for Slime and Rain
            window.initTeslaSlime = () => {
                const rainCanvas = document.getElementById('slime-rain-canvas');
                const edgeCanvas = document.getElementById('edge-slime-canvas');
                if (!rainCanvas || !edgeCanvas || rainCanvas.hasAttribute('data-initialized')) return;
                
                rainCanvas.setAttribute('data-initialized', 'true');

                const rCtx = rainCanvas.getContext('2d');
                const eCtx = edgeCanvas.getContext('2d');
                let width, height;

                function resize() {
                    width = rainCanvas.width = edgeCanvas.width = window.innerWidth;
                    height = rainCanvas.height = edgeCanvas.height = window.innerHeight;
                }
                window.addEventListener('resize', resize);
                resize();

                class Particle {
                    constructor(isEdge = false) {
                        this.isEdge = isEdge;
                        this.reset();
                    }

                    reset() {
                        if (this.isEdge) {
                            const onLeft = Math.random() > 0.5;
                            this.x = onLeft ? Math.random() * 25 : width - Math.random() * 25;
                            this.size = Math.random() * 3 + 1.5;
                            this.speed = Math.random() * 0.4 + 0.1;
                            this.gravity = 0.005;
                            this.color = '#39ff14';
                        } else {
                            this.x = Math.random() * width;
                            this.size = Math.random() * 30 + 5;
                            this.speed = Math.random() * 1.5 + 0.5;
                            this.gravity = 0.02;
                            const r = Math.random();
                            if (r > 0.5) this.color = '#39ff14';
                            else if (r > 0.15) this.color = '#f1c40f';
                            else this.color = '#8e44ad';
                        }
                        this.y = -Math.random() * 1000 - 100;
                    }

                    update() {
                        this.speed += this.gravity;
                        this.y += this.speed;
                        if (this.y > height + 200) this.reset();
                    }

                    draw(ctx) {
                        ctx.fillStyle = this.color;
                        ctx.beginPath();
                        if (this.isEdge) {
                            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                            ctx.rect(this.x - this.size * 0.8, 0, this.size * 1.6, this.y);
                        } else {
                            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                            ctx.rect(this.x - this.size * 0.8, this.y - this.size * 2, this.size * 1.6, this.size * 2);
                        }
                        ctx.fill();
                        ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';
                        ctx.beginPath();
                        ctx.arc(this.x - this.size/3, this.y - this.size/3, this.size/4, 0, Math.PI * 2);
                        ctx.fill();
                    }
                }

                const rainParticles = [];
                const edgeParticles = [];
                for (let i = 0; i < 40; i++) rainParticles.push(new Particle(false));
                for (let i = 0; i < 70; i++) edgeParticles.push(new Particle(true));

                function animate() {
                    rCtx.clearRect(0, 0, width, height);
                    eCtx.clearRect(0, 0, width, height);
                    rainParticles.forEach(p => { p.update(); p.draw(rCtx); });
                    edgeParticles.forEach(p => { p.update(); p.draw(eCtx); });
                    requestAnimationFrame(animate);
                }
                animate();
            };
            document.addEventListener('turbo:load', window.initTeslaSlime);
        </script>
    </head>
