let currentQuestion = 0;
let scores = { fromage: 0, slime: 0, police: 0, rat: 0 };

const portal       = document.getElementById('quiz-portal');
const quizContainer = document.getElementById('quiz-container');
const resultContainer = document.getElementById('result-container');
const questionText = document.getElementById('question-text');
const answersContainer = document.getElementById('answers-container');
const progressBar  = document.getElementById('progress-bar');
const progressPct  = document.getElementById('progress-pct');
const questionCounter = document.getElementById('question-counter');

document.getElementById('start-btn').addEventListener('click', startQuiz);
document.getElementById('retry-btn').addEventListener('click', resetQuiz);

function startQuiz() {
    portal.classList.add('hidden');
    quizContainer.classList.remove('hidden');
    showQuestion(0);
}

function showQuestion(index) {
    const q = QUESTIONS[index];
    const pct = Math.round((index / QUESTIONS.length) * 100);

    questionCounter.textContent = `Question ${index + 1} / ${QUESTIONS.length}`;
    progressPct.textContent = `${pct}%`;
    progressBar.style.width = `${pct}%`;

    // Animate card out then in
    const card = document.getElementById('question-card');
    card.style.opacity = '0';
    card.style.transform = 'translateY(20px)';

    setTimeout(() => {
        questionText.textContent = q.text;
        answersContainer.innerHTML = '';

        q.answers.forEach((answer, i) => {
            const btn = document.createElement('button');
            btn.className = [
                'w-full text-left px-6 py-5 rounded-2xl border-2 border-mauve-dark',
                'bg-black/30 text-white font-bold uppercase text-xs tracking-widest',
                'hover:border-accent hover:bg-accent/10 hover:text-accent',
                'active:scale-95 transition-all duration-200',
                'flex items-center gap-4'
            ].join(' ');

            const letter = String.fromCharCode(65 + i); // A, B, C, D
            btn.innerHTML = `
                <span class="flex-shrink-0 w-8 h-8 rounded-full border-2 border-current flex items-center justify-center font-mystere text-lg">${letter}</span>
                <span>${answer.text}</span>
            `;

            btn.addEventListener('click', () => selectAnswer(answer.scores));
            answersContainer.appendChild(btn);
        });

        card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
    }, 200);
}

function selectAnswer(answerScores) {
    // Disable all buttons
    const btns = answersContainer.querySelectorAll('button');
    btns.forEach(b => b.disabled = true);

    // Add scores
    for (const [key, val] of Object.entries(answerScores)) {
        scores[key] += val;
    }

    currentQuestion++;

    if (currentQuestion < QUESTIONS.length) {
        setTimeout(() => showQuestion(currentQuestion), 300);
    } else {
        setTimeout(showResult, 400);
    }
}

function showResult() {
    // Update progress to 100%
    progressBar.style.width = '100%';
    progressPct.textContent = '100%';

    // Find winning archetype
    const winner = Object.entries(scores).reduce((a, b) => a[1] > b[1] ? a : b)[0];
    const result = RESULTS[winner];

    document.getElementById('result-title').textContent = result.emoji + ' ' + result.title;
    document.getElementById('result-subtitle').textContent = result.subtitle;
    document.getElementById('result-description').textContent = result.description;
    document.getElementById('result-image').src = result.image;
    document.getElementById('result-image').alt = result.title;

    // Transition
    const card = document.getElementById('question-card');
    card.style.opacity = '0';
    card.style.transform = 'translateY(-20px)';

    setTimeout(() => {
        quizContainer.classList.add('hidden');
        resultContainer.classList.remove('hidden');
        resultContainer.style.opacity = '0';
        resultContainer.style.transform = 'translateY(30px)';
        resultContainer.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        setTimeout(() => {
            resultContainer.style.opacity = '1';
            resultContainer.style.transform = 'translateY(0)';
        }, 50);
    }, 300);
}

function resetQuiz() {
    currentQuestion = 0;
    scores = { fromage: 0, slime: 0, police: 0, rat: 0 };

    resultContainer.classList.add('hidden');
    quizContainer.classList.remove('hidden');

    progressBar.style.width = '0%';
    progressPct.textContent = '0%';

    showQuestion(0);
}
</script>
{% endblock %}
